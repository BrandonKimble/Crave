+
+class MapCameraAnimationCompleteEvent(
+    view: View?,
+    private val animationCompletionId: String?,
+    private val status: String
+) : AbstractEvent(view, EventTypes.MAP_CAMERA_ANIMATION_COMPLETE) {
+    override val key
+        get() = EventKeys.MAP_CAMERA_ANIMATION_COMPLETE.value
+
+    override val payload: WritableMap
+        get() {
+            val payload = Arguments.createMap()
+            if (animationCompletionId != null) {
+                payload.putString("animationCompletionId", animationCompletionId)
+            } else {
+                payload.putNull("animationCompletionId")
+            }
+            payload.putString("status", status)
+            return payload
+        }
+}
