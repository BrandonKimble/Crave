  collaborators FavoriteListCollaborator[]

  @@unique([ownerUserId, listType, name], map: "favorite_lists_owner_type_name")
  @@unique([ownerUserId, systemKind], map: "favorite_lists_owner_system_kind")
  @@index([ownerUserId], map: "idx_favorite_lists_owner")
  @@index([visibility], map: "idx_favorite_lists_visibility")
  @@index([listType], map: "idx_favorite_lists_type")
  @@index([updatedAt(sort: Desc)], map: "idx_favorite_lists_updated_at")
  @@map("favorite_lists")
