model OnDemandRequest {
  requestId             String                @id @default(dbgenerated("gen_random_uuid()")) @map("request_id") @db.Uuid
  term                  String                @db.VarChar(255)
  entityType            EntityType            @map("entity_type")
  marketKey             String                @map("market_key") @db.VarChar(255)
  distinctUserCount     Int                   @default(0) @map("distinct_user_count")
  lastSeenAt            DateTime              @default(now()) @map("last_seen_at")
  metadata              Json?                 @default("{}")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")
  entityId              String?               @map("entity_id") @db.Uuid
  reason                OnDemandReason
  resultRestaurantCount Int                   @default(0) @map("result_restaurant_count")
  resultFoodCount       Int                   @default(0) @map("result_food_count")
  entity                Entity?               @relation(fields: [entityId], references: [entityId])
  requestUsers          OnDemandRequestUser[]

  @@unique([term, entityType, reason, marketKey])
  @@index([reason], map: "idx_on_demand_requests_reason")
  @@index([lastSeenAt(sort: Desc)], map: "idx_on_demand_requests_last_seen_at")
  @@map("collection_on_demand_requests")
}

model OnDemandRequestUser {
  requestId String          @map("request_id") @db.Uuid
  userId    String          @map("user_id") @db.Uuid
  createdAt DateTime        @default(now()) @map("created_at")
  request   OnDemandRequest @relation(fields: [requestId], references: [requestId], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([requestId, userId])
  @@index([userId], map: "idx_collection_on_demand_request_users_user_id")
  @@index([createdAt(sort: Desc)], map: "idx_collection_on_demand_request_users_created_at")
  @@map("collection_on_demand_request_users")
}

