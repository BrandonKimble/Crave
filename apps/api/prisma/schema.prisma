/// Canonicalization lifecycle for entities. `pending` = quarantined (collection coined a
/// new attribute that the ontology hasn't adjudicated yet): excluded from all read
/// surfaces (autocomplete, search, display) but still matchable by resolution so repeat
/// mentions dedupe onto it. The ontology worker promotes (active), merges, or rejects.
enum EntityStatus {
  active
  pending
  archived

  @@map("entity_status")
