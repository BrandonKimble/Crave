model PollTopic {
  topicId                     String          @id @default(dbgenerated("gen_random_uuid()")) @map("topic_id") @db.Uuid
  title                       String          @db.VarChar(255)
  description                 String?         @db.VarChar(500)
  marketKey                   String?         @map("market_key") @db.VarChar(255)
  region                      String?         @db.VarChar(255)
  country                     String?         @db.VarChar(2)
  /// §22 item 4 re-key: new supply attaches topics to the place catalog.
  /// Old rows keep marketKey; new rows carry placeId (marketKey best-effort
  /// shim for the item-5 feed).
  placeId                     String?         @map("place_id") @db.Uuid
  categoryEntityIds           String[]        @default([]) @map("category_entity_ids") @db.Uuid
  seedEntityIds               String[]        @default([]) @map("seed_entity_ids") @db.Uuid
  status                      PollTopicStatus
  metadata                    Json?           @default("{}")
  createdByUserId             String?         @map("created_by_user_id") @db.Uuid
  createdAt                   DateTime        @default(now()) @map("created_at")
  updatedAt                   DateTime        @updatedAt @map("updated_at")
  targetDishId                String?         @map("target_dish_id") @db.Uuid
  targetRestaurantId          String?         @map("target_restaurant_id") @db.Uuid
  targetFoodAttributeId       String?         @map("target_food_attribute_id") @db.Uuid
  targetRestaurantAttributeId String?         @map("target_restaurant_attribute_id") @db.Uuid
  topicType                   PollTopicType   @default(best_dish) @map("topic_type")
  targetDish                  Entity?         @relation("PollTopicTargetDish", fields: [targetDishId], references: [entityId])
  targetRestaurant            Entity?         @relation("PollTopicTargetRestaurant", fields: [targetRestaurantId], references: [entityId])
  targetFoodAttribute         Entity?         @relation("PollTopicTargetFoodAttribute", fields: [targetFoodAttributeId], references: [entityId])
  targetRestaurantAttribute   Entity?         @relation("PollTopicTargetRestaurantAttribute", fields: [targetRestaurantAttributeId], references: [entityId])
  polls                       Poll[]

  @@index([marketKey], map: "idx_poll_topics_market_key")
  @@index([placeId], map: "idx_poll_topics_place_id")
  @@index([createdByUserId], map: "idx_poll_topics_created_by_user")
  @@index([status], map: "idx_poll_topics_status")
  @@map("poll_topics")
}

model Poll {
  pollId             String                 @id @default(dbgenerated("gen_random_uuid()")) @map("poll_id") @db.Uuid
  topicId            String?                @map("topic_id") @db.Uuid
  question           String                 @db.VarChar(500)
  state              PollState
  origin             PollOrigin             @default(user)
  mode               PollMode               @default(ranked)
  axis               Json?
  marketKey          String?                @map("market_key") @db.VarChar(255)
  /// §22 item 4 re-key: new supply-published polls attach to placeId (place
  /// catalog). Existing polls carry marketKey; old rows untouched.
  placeId            String?                @map("place_id") @db.Uuid
  region             String?                @db.VarChar(255)
  scheduledFor       DateTime?              @map("scheduled_for")
  launchedAt         DateTime?              @map("launched_at")
  closedAt           DateTime?              @map("closed_at")
  graduatedAt        DateTime?              @map("graduated_at")
  allowUserAdditions Boolean                @default(true) @map("allow_user_additions")
  audienceFilters    Json?                  @map("audience_filters")
  metadata           Json?                  @default("{}")
  createdByUserId    String?                @map("created_by_user_id") @db.Uuid
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")
  comments           PollComment[]
  leaderboardEntries PollLeaderboardEntry[]
  endorsements       PollEndorsement[]
  topic              PollTopic?             @relation(fields: [topicId], references: [topicId], onDelete: Cascade)

  @@index([topicId], map: "idx_polls_topic_id")
  @@index([state], map: "idx_polls_state")
  @@index([marketKey], map: "idx_polls_market_key")
  @@index([placeId], map: "idx_polls_place_id")
  @@index([createdByUserId], map: "idx_polls_created_by_user")
  @@map("polls")
}

/// The discussion-thread spine (Phase 2 schema; CRUD + sort land in Phase 4).
/// A poll comment is the primary unit — the leaderboard is projected over these.
model PollComment {
  commentId        String                      @id @default(dbgenerated("gen_random_uuid()")) @map("comment_id") @db.Uuid
  pollId           String                      @map("poll_id") @db.Uuid
  userId           String                      @map("user_id") @db.Uuid
  parentCommentId  String?                     @map("parent_comment_id") @db.Uuid
  body             String                      @db.Text
  score            Int                         @default(0)
  publicId         String                      @unique @map("public_id") @db.VarChar(32)
  moderationStatus PollCommentModerationStatus @default(pending) @map("moderation_status")
  extractionStatus PollCommentExtractionStatus @default(pending) @map("extraction_status")
  entitySpans      Json?                       @map("entity_spans")
  loggedAt         DateTime                    @default(now()) @map("logged_at")
  editedAt         DateTime?                   @map("edited_at")
  deletedAt        DateTime?                   @map("deleted_at")
  poll             Poll                        @relation(fields: [pollId], references: [pollId], onDelete: Cascade)
  user             User                        @relation(fields: [userId], references: [userId], onDelete: Cascade)
  parent           PollComment?                @relation("PollCommentThread", fields: [parentCommentId], references: [commentId], onDelete: NoAction, onUpdate: NoAction)
  children         PollComment[]               @relation("PollCommentThread")
  likes            PollCommentLike[]
  reports          PollCommentReport[]

  @@index([pollId, score(sort: Desc)], map: "idx_poll_comments_poll_score")
  @@index([pollId, loggedAt(sort: Desc)], map: "idx_poll_comments_poll_logged")
  @@index([parentCommentId], map: "idx_poll_comments_parent")
  @@index([userId], map: "idx_poll_comments_user")
  /// Restaurant-mentions JSONB containment (entitySpans @> [{entityId}]) — without
  /// this every GET /polls/restaurants/:id/mentions seq-scans poll_comments.
  @@index([entitySpans(ops: JsonbPathOps)], map: "idx_poll_comments_entity_spans_gin", type: Gin)
  @@map("poll_comments")
}

/// Reddit-style per-comment likes (drive thread sort + endorsement signal).
model PollCommentLike {
  commentId String      @map("comment_id") @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  loggedAt  DateTime    @default(now()) @map("logged_at")
  comment   PollComment @relation(fields: [commentId], references: [commentId], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([commentId, userId])
  @@index([commentId], map: "idx_poll_comment_likes_comment")
  @@index([userId], map: "idx_poll_comment_likes_user")
  @@map("poll_comment_likes")
}

/// Leaderboard projection (Phase 2 schema; Phase 4 fills it). Subject = a
/// restaurant entity OR a restaurant+dish Connection, mirroring Crave-Score subjects.
/// Rebuilt on interaction + authoritatively at close; never a vote table of record.
model PollLeaderboardEntry {
  pollId            String                     @map("poll_id") @db.Uuid
  subjectType       PollLeaderboardSubjectType @map("subject_type")
  // Either an entity UUID (restaurant-axis) or a poll-local "restaurantId::foodId"
  // composite (dish-axis) — so it's a plain string, not a UUID column.
  subjectId         String                     @map("subject_id")
  distinctEndorsers Int                        @default(0) @map("distinct_endorsers")
  score             Decimal                    @default(0) @db.Decimal(18, 6)
  rank              Int                        @default(0)
  updatedAt         DateTime                   @updatedAt @map("updated_at")
  poll              Poll                       @relation(fields: [pollId], references: [pollId], onDelete: Cascade)

  @@id([pollId, subjectType, subjectId])
  @@index([pollId, rank], map: "idx_poll_leaderboard_poll_rank")
  @@map("poll_leaderboard_entries")
}

/// A user's direct endorsement of a leaderboard subject within a poll — the §13A
/// public "endorse" (like) signal applied per-candidate, powering tap-to-endorse on
/// the poll bars. One row per (poll, subject, user); toggled on/off; folded into
/// PollLeaderboardEntry.distinctEndorsers alongside comment-derived endorsers.
model PollEndorsement {
  pollId      String                     @map("poll_id") @db.Uuid
  subjectType PollLeaderboardSubjectType @map("subject_type")
  // Either an entity UUID (restaurant-axis) or a poll-local "restaurantId::foodId"
  // composite (dish-axis) — a plain string, not a UUID column.
  subjectId   String                     @map("subject_id")
  userId      String                     @map("user_id") @db.Uuid
  createdAt   DateTime                   @default(now()) @map("created_at")
  poll        Poll                       @relation(fields: [pollId], references: [pollId], onDelete: Cascade)
  user        User                       @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([pollId, subjectType, subjectId, userId])
  @@index([pollId, subjectType, subjectId], map: "idx_poll_endorsement_subject")
  @@index([userId], map: "idx_poll_endorsement_user")
  @@map("poll_endorsements")
}

model NotificationDevice {
  deviceId      String               @id @default(dbgenerated("gen_random_uuid()")) @map("device_id") @db.Uuid
  userId        String?              @map("user_id") @db.VarChar(255)
  expoPushToken String               @unique @map("expo_push_token") @db.VarChar(255)
  provider      NotificationProvider @default(expo)
  platform      String?              @db.VarChar(50)
  appVersion    String?              @map("app_version") @db.VarChar(32)
  locale        String?              @db.VarChar(16)
  // §4 home-place registration: placeAt(home location) — the smallest catalog
  // place containing the coordinate the device registered with. NULL = we
  // honestly don't know where this device lives (no location at registration,
  // or the user revoked it) → the device receives NO poll pushes. Bare uuid
  // (no FK): catalog places can merge/expire; a dangling id simply matches no
  // subtree, which is the same honest no-push.
  homePlaceId   String?              @map("home_place_id") @db.Uuid
  metadata      Json?                @default("{}")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  notifications Notification[]

  @@index([userId], map: "idx_notification_devices_user_id")
  @@index([homePlaceId], map: "idx_notification_devices_home_place_id")
  @@map("notification_devices")
}

model Notification {
  notificationId String              @id @default(dbgenerated("gen_random_uuid()")) @map("notification_id") @db.Uuid
  type           NotificationType    @map("notification_type")
  status         NotificationStatus  @default(pending) @map("status")
  payload        Json?               @default("{}")
  scheduledFor   DateTime?           @map("scheduled_for")
