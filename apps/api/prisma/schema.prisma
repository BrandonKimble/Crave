// ============ PHASE A (master plan §1/§3): Place Catalog + Signals ============

// §1 Place Catalog: containment DAG, open level codes, two-tier geometry.
model Place {
  placeId           String    @id @default(dbgenerated("gen_random_uuid()")) @map("place_id") @db.Uuid
  name              String    @db.VarChar(255)
  localScriptAlias  String?   @map("local_script_alias") @db.VarChar(255)
  /// OPEN vocabulary (municipality, municipalitySubdivision, neighbourhood,
  /// county, subdivision, country, …) — stored, never switched on.
  providerLevelCode String    @map("provider_level_code") @db.VarChar(64)
  countryCode       String    @map("country_code") @db.VarChar(2)
  subdivisionCode   String?   @map("subdivision_code") @db.VarChar(8)
  /// COUNTY AXIS (§18 item 8, ratified 2026-07-19): the identity-law
  /// discriminator for same-name municipalities within one subdivision.
  /// Stores the provider's county-axis NAME normalized (TomTom
  /// countrySecondarySubdivision "Tarrant"; Census county name with the
  /// designator stripped, "Tarrant County" → "Tarrant") — a NAME, not a
  /// code, because no stable cross-provider county code exists. NULL =
  /// county unknown (gap-filled by later observations) or meaningless
  /// (nodes at/above the county rung — a state is not inside a county).
  county            String?   @db.VarChar(128)
  /// DAG edges captured from the reverse-geocode chain at creation.
  parentPlaceIds    String[]  @default([]) @map("parent_place_ids") @db.Uuid
  centroidLat       Decimal?  @map("centroid_lat") @db.Decimal(10, 8)
  centroidLng       Decimal?  @map("centroid_lng") @db.Decimal(11, 8)
  bboxMinLat        Decimal?  @map("bbox_min_lat") @db.Decimal(10, 8)
  bboxMinLng        Decimal?  @map("bbox_min_lng") @db.Decimal(11, 8)
  bboxMaxLat        Decimal?  @map("bbox_max_lat") @db.Decimal(10, 8)
  bboxMaxLng        Decimal?  @map("bbox_max_lng") @db.Decimal(11, 8)
  timeZone          String?   @map("time_zone") @db.VarChar(64)
  provider          String    @default("tomtom") @db.VarChar(32)
  providerPlaceId   String?   @map("provider_place_id") @db.VarChar(128)
  createdAt         DateTime  @default(now()) @map("created_at")
  promotedAt        DateTime? @map("promoted_at")

  // Identity law: silent-fork prevention. The REAL unique constraint is a raw
  // expression index (migration 20260720050000): UNIQUE (country_code,
  // subdivision_code, lower(county), provider_level_code, lower(name))
  // NULLS NOT DISTINCT — case-insensitive names/counties + NULLs treated as
  // equal, neither of which Prisma's @@unique can express. Do not re-add
  // @@unique here. NULLS NOT DISTINCT means at most ONE county-unknown row
  // per (country, subdivision, level, name); a county-carrying row may
  // coexist with it — whether that coexistence is legitimate (genuinely
  // distinct places) or a gap-fill (the NULL row adopts the county) is the
  // MERGE LAW's decision (PlacesCatalogService.resolveIdentity), not the
  // index's.
  @@index([countryCode, subdivisionCode])
  @@index([providerPlaceId])
  @@map("places")
}

// Tier-2 geometry side table (hot naming row stays lean). geometry column is
// PostGIS — added via raw SQL in the migration (Unsupported in prisma):
//   geometry geometry(MultiPolygon, 4326), GiST index.
model PlaceGeometry {
  placeId            String   @id @map("place_id") @db.Uuid
  providerBoundaryId String?  @map("provider_boundary_id") @db.VarChar(128)
  fetchedAt          DateTime @default(now()) @map("fetched_at")

  @@map("place_geometries")
}

// §2 Tier-2 polygon promotion queue (scarce pool, "earned moments"): placeId
// PK ⇒ enqueue is idempotent (queued OR promoted = conflict no-op). trigger
// is OPEN vocabulary (§1 stance: stored, never switched on). attempts counts
// draw-consuming misses (no cap — the pool bounds spend); lastAttemptAt gates
// retry to the next MONTH window (the K4 monthly pool is the backoff clock);
// providerBoundaryId caches a cheap-resolved TomTom geometry id across
// windows. See PlacesPromotionService.
model PlaceGeometryPromotion {
  placeId            String    @id @map("place_id") @db.Uuid
  trigger            String    @db.VarChar(32)
  enqueuedAt         DateTime  @default(now()) @map("enqueued_at")
  promotedAt         DateTime? @map("promoted_at")
  attempts           Int       @default(0)
  lastAttemptAt      DateTime? @map("last_attempt_at")
  providerBoundaryId String?   @map("provider_boundary_id") @db.VarChar(128)

  @@index([promotedAt, enqueuedAt], map: "idx_place_geometry_promotions_drain")
  @@map("place_geometry_promotions")
}

// §3 Signals Ledger: append-only, immutable, geo ALWAYS a bbox (point =
// zero-area), actorId pseudonymous. Monthly partitioning applied at the SQL
// layer later (native partitioning is a follow-up; the table is append-only
// so re-partitioning is cheap).
/// §3: MONTHLY RANGE-PARTITIONED on occurred_at (raw-SQL migration
/// 20260720110000). The DB primary key is COMPOSITE (signal_id, occurred_at)
/// — Postgres law: a unique constraint on a partitioned table must include
/// the partition key. Prisma cannot express partitioning, so this model
/// deliberately keeps the simple @id (signal_id is still globally unique in
/// practice — gen_random_uuid); the ledger is append-only + raw-SQL-read, so
/// no findUnique/update/delete ever runs against the composite key. Future
/// partitions are created ahead by SignalPartitionMaintenanceService.
model Signal {
  signalId    String   @id @default(dbgenerated("gen_random_uuid()")) @map("signal_id") @db.Uuid
  /// ACT kinds only; qualifiers live in meta (judged at read):
  /// search | autocomplete_selection | entity_view | favorite_added |
  /// poll_vote | poll_comment | poll_created | viewport_dwell
  kind        String   @db.VarChar(32)
  subjectType String   @map("subject_type") @db.VarChar(16) // entity | term | none
  subjectId   String?  @map("subject_id") @db.Uuid
  subjectText String?  @map("subject_text") @db.VarChar(255)
  geoMinLat   Decimal  @map("geo_min_lat") @db.Decimal(10, 8)
  geoMinLng   Decimal  @map("geo_min_lng") @db.Decimal(11, 8)
  geoMaxLat   Decimal  @map("geo_max_lat") @db.Decimal(10, 8)
  geoMaxLng   Decimal  @map("geo_max_lng") @db.Decimal(11, 8)
  actorId     String   @map("actor_id") @db.Uuid
  occurredAt  DateTime @map("occurred_at")
  /// WHEN the ledger learned of the act (occurredAt = when it happened).
  /// Drives the aggregate's watermark rebuild (red-team 1b): late/backfilled
  /// writes are picked up by recorded-at, so every signal eventually lands in
  /// its occurred-at day slice.
  recordedAt  DateTime @default(now()) @map("recorded_at") @db.Timestamptz(6)
  meta        Json?

  @@index([occurredAt])
  @@index([kind, occurredAt])
  @@index([subjectId])
  // Per-actor reader lane (§22 item 6): recently-viewed + recent-searches read
  // one actor's acts of one kind newest-first.
  @@index([actorId, kind, occurredAt])
  @@index([recordedAt])
  // Raw-SQL partial expression index (migration 20260719235000):
  // (COALESCE(meta->>'searchRequestId', meta->>'cacheRevealRequestId'),
  // occurred_at) WHERE either id present — the ledger-wide retry-dedupe probe
  // (red-team 1c). Not expressible in Prisma; do not re-add here.
  @@map("signals")
}

// §3 aggregate: day × actor × place × subject × kind — a DERIVED read model
// over the signals ledger (rebuildable from scratch; days rebuild via the
// recorded-at watermark; redirects applied AT READ, never baked in). place_id
// NULL is the GLOBAL tile (every signal exactly once); non-NULL rows are the
// §3 containment-TILING attribution — the smallest place CONTAINING the
// signal geo plus the coarsest catalog level(s) TILING the places contained
// in it (containment, never intersection; storage O(few) per signal) — with
// read-time inheritance supplying the "every place in view at weight 1"
// semantics. Rows are only ever written by whole-day delete-and-reinsert
// under an advisory lock (SignalDemandAggregateService), so no unique
// constraint is declared; rowId is a Prisma-required surrogate.
model SignalDemandDaily {
  rowId          String   @id @default(dbgenerated("gen_random_uuid()")) @map("row_id") @db.Uuid
  day            DateTime @db.Date
  placeId        String?  @map("place_id") @db.Uuid
  actorId        String   @map("actor_id") @db.Uuid
  kind           String   @db.VarChar(32)
  subjectType    String   @map("subject_type") @db.VarChar(16)
  subjectId      String?  @map("subject_id") @db.Uuid
  subjectText    String?  @map("subject_text") @db.VarChar(255)
  signalCount    Int      @map("signal_count")
  lastOccurredAt DateTime @map("last_occurred_at")

  @@index([day])
  @@index([subjectId, day])
  @@index([subjectText, day])
  @@index([actorId, day])
  @@index([placeId, day])
  @@map("signal_demand_daily")
}

// Single-row watermark state for the aggregate rebuild cron (red-team 1b):
// each pass rebuilds every day carrying signals recorded since the watermark.
// The id=1 CHECK constraint (raw SQL, migration 20260719235000) pins it to
// one row.
model SignalDemandRebuildState {
  id        Int       @id @default(1)
  watermark DateTime? @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("signal_demand_rebuild_state")
}

// Pseudonymous actor mapping — the severable deletion story (§3).
model SignalActor {
  actorId   String   @id @default(dbgenerated("gen_random_uuid()")) @map("actor_id") @db.Uuid
  userId    String?  @unique @map("user_id") @db.Uuid
  deviceKey String?  @unique @map("device_key") @db.VarChar(128)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("signal_actors")
}

// Identity is a judgment (§3): merges write redirects; readers resolve at
// read. The ledger is never rekeyed.
model EntityRedirect {
  fromEntityId String   @id @map("from_entity_id") @db.Uuid
  toEntityId   String   @map("to_entity_id") @db.Uuid
  redirectedAt DateTime @default(now()) @map("redirected_at")

  @@index([toEntityId])
  @@map("entity_redirects")
}

// ============ §5 Sources + §4 poll supply (§22 item 4) ============

/// §5 sources: the calibration room. Every place's poll surface IS a source
/// (platform 'poll_surface', handle = placeId, anchorPlaceId = the place).
/// poll_surface rows carry NO engineId — the field is reddit-class only (§5:
/// poll evidence reaches collection only as demand through the ledger, never
/// as corpus).
model Source {
  sourceId      String   @id @default(dbgenerated("gen_random_uuid()")) @map("source_id") @db.Uuid
  platform      String   @db.VarChar(32)
  handle        String   @db.VarChar(255)
  anchorPlaceId String?  @map("anchor_place_id") @db.Uuid
  engineId      String?  @map("engine_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([platform, handle], map: "sources_platform_handle_key")
  @@index([anchorPlaceId], map: "idx_sources_anchor_place")
  @@map("sources")
}

/// §4 supply-controller state per place: the learned frontier, its phase
/// (warm_start until the first cohort closes, then learned), and the credit
/// warrant accumulator (accrues at creditRate, decays 14d half-life, spent by
/// publishing). No caps exist anywhere in this row's semantics.
model PollPlaceSupply {
  placeId         String    @id @map("place_id") @db.Uuid
  frontier        Int
  phase           String    @db.VarChar(16)
  credit          Decimal   @default(0) @db.Decimal(18, 6)
  creditUpdatedAt DateTime? @map("credit_updated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("poll_place_supply")
}

/// §4 weekly-ritual publish ledger. The UNIQUE (placeId, weekOf-local) IS the
/// idempotency key: publish is atomic with this row, so the same local Sunday
/// can never double-publish.
model PollWeeklyTick {
  tickId         String   @id @default(dbgenerated("gen_random_uuid()")) @map("tick_id") @db.Uuid
  placeId        String   @map("place_id") @db.Uuid
  /// Local calendar date (YYYY-MM-DD) of the place's Sunday.
  weekOf         String   @map("week_of") @db.VarChar(10)
  publishedCount Int      @map("published_count")
  factors        Json?
  publishedAt    DateTime @default(now()) @map("published_at")

  @@unique([placeId, weekOf], map: "poll_weekly_ticks_place_week_key")
  @@map("poll_weekly_ticks")
}

/// §14.5 durable window store (durability leg, 2026-07-20): the WINDOW
/// CONSUMPTION of pools whose windows outlive a process. §16 classification
/// of the durability split (design of record):
///  - perMonth / perDay / grant pools (the money — TomTom 2,500 + 20,000/mo)
///    are DURABLE: consumption is written through on every reconcile (they
///    are low-rate; a synchronous durable increment is correct-first) and
///    loaded at boot — a restart can never reset a month ledger.
///  - perMinute pools (reddit 100/min, gemini TPM mirror) stay IN-MEMORY by
///    design: a restart loses ≤1 minute of window, which is harmless, and
///    putting DB I/O on the per-request hot path buys nothing. Their
///    declared-vs-actual LEDGER pairs likewise stay in-memory (drift is a
///    statistical instrument; restart loss is noise) — a durable draw ledger
///    is the §18.5 ops-readers leg, not this one.
/// Reservations are NEVER stored: they are seconds-scale and TTL-expiring
/// (§14.2 leaks expire) — only confirmed consumption is durable.
model PoolWindowConsumption {
  /// PoolConfig.name, e.g. 'tomtom.scarcePolygons'.
  poolName  String   @map("pool_name") @db.VarChar(128)
  /// Canonical UTC window label: perMonth 'YYYY-MM', perDay 'YYYY-MM-DD',
  /// grant 'grant' (grants never roll).
  windowKey String   @map("window_key") @db.VarChar(32)
  consumed  Float    @default(0)
  /// Grant pools only: owner-minted capacity on top of the registered base.
  granted   Float    @default(0)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@id([poolName, windowKey])
  @@map("pool_window_consumption")
}
