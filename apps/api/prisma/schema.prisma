  shortName          String?                                      @map("short_name") @db.VarChar(255)
  countryCode        String                                       @default("US") @map("country_code") @db.VarChar(2)
  stateCode          String?                                      @map("state_code") @db.VarChar(8)
  centerLatitude     Decimal?                                     @map("center_latitude") @db.Decimal(11, 8)
  centerLongitude    Decimal?                                     @map("center_longitude") @db.Decimal(11, 8)
  bboxNeLat          Decimal?                                     @map("bbox_ne_latitude") @db.Decimal(11, 8)
  bboxNeLng          Decimal?                                     @map("bbox_ne_longitude") @db.Decimal(11, 8)
  bboxSwLat          Decimal?                                     @map("bbox_sw_latitude") @db.Decimal(11, 8)
  bboxSwLng          Decimal?                                     @map("bbox_sw_longitude") @db.Decimal(11, 8)
  geometry           Unsupported("geometry(MultiPolygon, 4326)")?
  metadata           Json?                                        @default("{}")
  fetchedAt          DateTime                                     @default(now()) @map("fetched_at")
  createdAt          DateTime                                     @default(now()) @map("created_at")
  updatedAt          DateTime                                     @updatedAt @map("updated_at")
  markets            Market[]

  @@unique([sourceProvider, sourceBoundaryId, sourceBoundaryType], map: "uq_geo_boundary_features_source")
  @@index([sourceProvider, sourceBoundaryType], map: "idx_geo_boundary_features_source_type")
  @@index([stateCode], map: "idx_geo_boundary_features_state")
  @@index([centerLatitude, centerLongitude], map: "idx_geo_boundary_features_center")
  @@map("geo_boundary_features")
}

model MarketBootstrapEvent {
  marketBootstrapEventId String   @id @default(dbgenerated("gen_random_uuid()")) @map("market_bootstrap_event_id") @db.Uuid
  requestId              String?  @map("request_id") @db.Uuid
  sourceProvider         String   @map("source_provider") @db.VarChar(64)
  sourceBoundaryId       String?  @map("source_boundary_id") @db.VarChar(255)
  sourceBoundaryType     String?  @map("source_boundary_type") @db.VarChar(64)
  eventType              String   @map("event_type") @db.VarChar(64)
  triggerKind            String?  @map("trigger_kind") @db.VarChar(64)
  marketKey              String?  @map("market_key") @db.VarChar(255)
  attemptIndex           Int?     @map("attempt_index")
  uncoveredAreaMeters    Float?   @map("uncovered_area_meters")
  uncoveredAreaShare     Float?   @map("uncovered_area_share")
  candidateName          String?  @map("candidate_name") @db.VarChar(255)
  stopReason             String?  @map("stop_reason") @db.VarChar(64)
  lookupLatitude         Decimal? @map("lookup_latitude") @db.Decimal(11, 8)
  lookupLongitude        Decimal? @map("lookup_longitude") @db.Decimal(11, 8)
  message                String?  @db.Text
  metadata               Json?    @default("{}")
  createdAt              DateTime @default(now()) @map("created_at")

  @@index([sourceProvider, sourceBoundaryId, sourceBoundaryType], map: "idx_market_bootstrap_events_source")
  @@index([eventType], map: "idx_market_bootstrap_events_event_type")
  @@index([createdAt(sort: Desc)], map: "idx_market_bootstrap_events_created_at")
  @@map("market_bootstrap_events")
}

model OnDemandRequest {
  requestId             String                @id @default(dbgenerated("gen_random_uuid()")) @map("request_id") @db.Uuid
  term                  String                @db.VarChar(255)
  entityType            EntityType            @map("entity_type")
  marketKey             String                @map("market_key") @db.VarChar(255)
  distinctUserCount     Int                   @default(0) @map("distinct_user_count")
  lastSeenAt            DateTime              @default(now()) @map("last_seen_at")
  lastQueuedAt          DateTime?             @map("last_queued_at")
  metadata              Json?                 @default("{}")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")
  entityId              String?               @map("entity_id") @db.Uuid
  entityIdentityKey     String                @default("no_entity") @map("entity_identity_key") @db.VarChar(64)
  reason                OnDemandReason
  resultRestaurantCount Int                   @default(0) @map("result_restaurant_count")
  resultFoodCount       Int                   @default(0) @map("result_food_count")
  entity                Entity?               @relation(fields: [entityId], references: [entityId])
  requestUsers          OnDemandRequestUser[]
  askEvents             OnDemandAskEvent[]

  @@unique([term, entityType, marketKey, entityIdentityKey], map: "uq_on_demand_request_identity")
  @@index([reason], map: "idx_on_demand_requests_reason")
  @@index([entityIdentityKey], map: "idx_on_demand_requests_entity_identity")
  @@index([lastSeenAt(sort: Desc)], map: "idx_on_demand_requests_last_seen_at")
  @@index([lastQueuedAt(sort: Desc)], map: "idx_on_demand_requests_last_queued_at")
  @@map("collection_on_demand_requests")
}

model OnDemandRequestUser {
  requestId   String          @map("request_id") @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  firstSeenAt DateTime        @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime        @default(now()) @map("last_seen_at")
  askCount    Int             @default(1) @map("ask_count")
  request     OnDemandRequest @relation(fields: [requestId], references: [requestId], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([requestId, userId])
  @@index([userId], map: "idx_collection_on_demand_request_users_user_id")
  @@index([lastSeenAt(sort: Desc)], map: "idx_collection_on_demand_request_users_last_seen_at")
  @@map("collection_on_demand_request_users")
}

model OnDemandAskEvent {
  askEventId            String           @id @default(dbgenerated("gen_random_uuid()")) @map("ask_event_id") @db.Uuid
  requestId             String?          @map("request_id") @db.Uuid
  userId                String?          @map("user_id") @db.Uuid
  term                  String           @db.VarChar(255)
  entityType            EntityType       @map("entity_type")
  entityId              String?          @map("entity_id") @db.Uuid
  reason                OnDemandReason
  marketKey             String           @map("market_key") @db.VarChar(255)
  collectableMarketKey  String?          @map("collectable_market_key") @db.VarChar(255)
  resultRestaurantCount Int?             @map("result_restaurant_count")
  resultFoodCount       Int?             @map("result_food_count")
  askedAt               DateTime         @default(now()) @map("asked_at") @db.Timestamptz(6)
  /// One search request can signal on-demand from TWO sites (interpretation-time
  /// unresolved + search-time low-result); this id dedupes ask events per request.
  searchRequestId       String?          @map("search_request_id") @db.Uuid
  metadata              Json?            @default("{}")
  entity                Entity?          @relation(fields: [entityId], references: [entityId], onDelete: SetNull)
  request               OnDemandRequest? @relation(fields: [requestId], references: [requestId], onDelete: SetNull)
  user                  User?            @relation(fields: [userId], references: [userId], onDelete: SetNull)

  @@index([askedAt(sort: Desc)], map: "idx_on_demand_ask_events_asked_at")
  @@index([marketKey, askedAt(sort: Desc)], map: "idx_on_demand_ask_events_market_time")
  @@index([collectableMarketKey, askedAt(sort: Desc)], map: "idx_on_demand_ask_events_collectable_market_time")
  @@index([requestId, askedAt(sort: Desc)], map: "idx_on_demand_ask_events_request_time")
  @@index([userId, askedAt(sort: Desc)], map: "idx_on_demand_ask_events_user_time")
  @@index([reason, entityType, marketKey, askedAt(sort: Desc)], map: "idx_on_demand_ask_events_reason_type_market")
  @@map("collection_on_demand_ask_events")
}

model KeywordAttemptHistory {
  collectableMarketKey String                 @map("collectable_market_key") @db.VarChar(255)
  normalizedTerm       String                 @map("normalized_term") @db.VarChar(255)
  lastAttemptAt        DateTime?              @map("last_attempt_at")
  lastSuccessAt        DateTime?              @map("last_success_at")
  lastOutcome          KeywordAttemptOutcome? @map("last_outcome")
  cooldownUntil        DateTime?              @map("cooldown_until")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")

  @@id([collectableMarketKey, normalizedTerm])
  @@index([collectableMarketKey], map: "idx_collection_keyword_attempt_history_collectable_market_key")
  @@index([cooldownUntil], map: "idx_collection_keyword_attempt_history_cooldown_until")
  @@map("collection_keyword_attempt_history")
}

