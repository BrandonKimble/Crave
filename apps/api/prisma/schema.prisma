generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "darwin"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [btree_gin, pg_trgm, postgis, vector]
}

model Entity {
  entityId                            String                      @id @default(dbgenerated("gen_random_uuid()")) @map("entity_id") @db.Uuid
  name                                String                      @db.VarChar(255)
  type                                EntityType
  status                              EntityStatus                @default(active)
  canonicalDomain                     String?                     @map("canonical_domain") @db.VarChar(255)
  aliases                             String[]                    @default([])
  /// KNOWLEDGE TIER (food entities only): synthesized canonical ingredient
  /// entity ids ("al pastor taco" -> pork, pineapple, ...). World knowledge,
  /// generated per dish by the offline synthesis pass — never testimony.
  canonicalIngredients                String[]                    @default([]) @map("canonical_ingredients") @db.Uuid
  /// Stamp for the offline dish-knowledge pass (canonical ingredients +
  /// established aliases). NULL = not yet synthesized.
  knowledgeSynthesizedAt              DateTime?                   @map("knowledge_synthesized_at")
  nameEmbedding                       Unsupported("vector(768)")? @map("name_embedding")
  nameEmbeddingStale                  Boolean                     @default(false) @map("name_embedding_stale")
  restaurantAttributes                String[]                    @default([]) @map("restaurant_attributes") @db.Uuid
  latitude                            Decimal?                    @db.Decimal(10, 8)
  longitude                           Decimal?                    @db.Decimal(11, 8)
  address                             String?                     @db.VarChar(500)
  restaurantMetadata                  Json?                       @map("restaurant_metadata")
  primaryLocationId                   String?                     @unique @map("primary_location_id") @db.Uuid
  lastUpdated                         DateTime                    @default(now()) @map("last_updated")
  createdAt                           DateTime                    @default(now()) @map("created_at")
  generalPraiseUpvotes                Int?                        @default(0) @map("general_praise_upvotes")
  city                                String?                     @map("city") @db.VarChar(255)
  region                              String?                     @map("region") @db.VarChar(255)
  country                             String?                     @map("country") @db.VarChar(2)
  postalCode                          String?                     @map("postal_code") @db.VarChar(32)
  priceLevel                          Int?                        @map("price_level")
  priceLevelUpdatedAt                 DateTime?                   @map("price_level_updated_at")
  lastPolledAt                        DateTime?                   @map("last_polled_at")
  foodConnections                     Connection[]                @relation("FoodEntity")
  restaurantConnections               Connection[]                @relation("RestaurantEntity")
  onDemandRequests                    OnDemandRequest[]
  restaurantPhotos                    Photo[]                     @relation("RestaurantPhotos")
  favoriteEvents                      UserFavoriteEvent[]
  pollTopicDishTargets                PollTopic[]                 @relation("PollTopicTargetDish")
  pollTopicRestaurantTargets          PollTopic[]                 @relation("PollTopicTargetRestaurant")
  pollTopicFoodAttributeTargets       PollTopic[]                 @relation("PollTopicTargetFoodAttribute")
  pollTopicRestaurantAttributeTargets PollTopic[]                 @relation("PollTopicTargetRestaurantAttribute")
  userFavorites                       UserFavorite[]
  favoriteListItems                   FavoriteListItem[]
  demandScoringCandidates             DemandScoringCandidate[]
  locations                           RestaurantLocation[]        @relation("RestaurantLocations")
  marketPresences                     EntityMarketPresence[]
  restaurantEvents                    RestaurantEvent[]           @relation("RestaurantEventRestaurant")
  restaurantEntityEvents              RestaurantEntityEvent[]     @relation("RestaurantEntityEventRestaurant")
  restaurantEntityEventTargets        RestaurantEntityEvent[]     @relation("RestaurantEntityEventTarget")
  restaurantEntitySignals             RestaurantEntitySignal[]    @relation("RestaurantEntitySignalRestaurant")
  restaurantEntitySignalTargets       RestaurantEntitySignal[]    @relation("RestaurantEntitySignalTarget")
  primaryLocation                     RestaurantLocation?         @relation("PrimaryLocation", fields: [primaryLocationId], references: [locationId])

  @@index([type], map: "idx_entities_type")
  @@index([type, status], map: "idx_entities_type_status")
  @@index([name], map: "idx_entities_name")
  @@index([canonicalDomain], map: "idx_entities_canonical_domain")
  @@index([type, canonicalDomain], map: "idx_entities_type_canonical_domain")
  @@index([aliases], map: "idx_entities_aliases")
  @@index([canonicalIngredients], map: "idx_entities_canonical_ingredients_gin", type: Gin)
  @@index([restaurantAttributes], map: "idx_entities_restaurant_attributes")
  @@index([longitude, latitude], map: "idx_entities_location")
  @@index([address], map: "idx_entities_address")
  @@index([city], map: "idx_entities_city")
  @@index([region], map: "idx_entities_region")
  @@index([country], map: "idx_entities_country")
  @@index([priceLevel], map: "idx_entities_price_level")
  @@index([lastPolledAt], map: "idx_entities_last_polled_at")
  @@index([primaryLocationId], map: "idx_entities_primary_location")
  @@index([lastUpdated(sort: Desc)], map: "idx_entities_last_updated")
  @@index([createdAt(sort: Desc)], map: "idx_entities_created_at")
  @@map("core_entities")
}

model EntityMarketPresence {
  entityId  String   @map("entity_id") @db.Uuid
  marketKey String   @map("market_key") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  entity    Entity   @relation(fields: [entityId], references: [entityId], onDelete: Cascade)

  @@id([entityId, marketKey])
  @@index([marketKey], map: "idx_entity_market_presence_market_key")
  @@index([entityId], map: "idx_entity_market_presence_entity_id")
  @@map("core_entity_market_presence")
}

model RestaurantLocation {
  locationId       String    @id @default(dbgenerated("gen_random_uuid()")) @map("location_id") @db.Uuid
  restaurantId     String    @map("restaurant_id") @db.Uuid
  googlePlaceId    String?   @unique @map("google_place_id") @db.VarChar(255)
  latitude         Decimal?  @db.Decimal(10, 8)
  longitude        Decimal?  @db.Decimal(11, 8)
  address          String?   @db.VarChar(500)
  city             String?   @db.VarChar(255)
  region           String?   @db.VarChar(255)
  country          String?   @db.VarChar(2)
  postalCode       String?   @map("postal_code") @db.VarChar(32)
  phoneNumber      String?   @map("phone_number") @db.VarChar(64)
  websiteUrl       String?   @map("website_url") @db.VarChar(2048)
  websiteDomain    String?   @map("website_domain") @db.VarChar(255)
  hours            Json?     @map("hours")
  utcOffsetMinutes Int?      @map("utc_offset_minutes")
  timeZone         String?   @map("time_zone") @db.VarChar(64)
  isPrimary        Boolean   @default(false) @map("is_primary")
  lastPolledAt     DateTime? @map("last_polled_at")
  /// Google businessStatus from the last refresh poll (CLOSED_PERMANENTLY etc.);
  /// written by refreshStaleLocations, acted on by the janitor.
  businessStatus   String?   @map("business_status") @db.VarChar(32)
  movedPlaceId     String?   @map("moved_place_id") @db.VarChar(255)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @map("updated_at")
  restaurant       Entity    @relation("RestaurantLocations", fields: [restaurantId], references: [entityId], onDelete: Cascade)
  primaryFor       Entity?   @relation("PrimaryLocation")

  savedFavorites UserFavorite[]
  savedListItems FavoriteListItem[]

  @@index([restaurantId], map: "idx_restaurant_locations_restaurant")
  @@index([restaurantId, isPrimary], map: "idx_restaurant_locations_primary")
  @@index([restaurantId, websiteDomain], map: "idx_restaurant_locations_restaurant_domain")
  @@index([longitude, latitude], map: "idx_restaurant_locations_location")
  @@index([googlePlaceId], map: "idx_restaurant_locations_google_place_id")
  @@index([websiteDomain], map: "idx_restaurant_locations_website_domain")
  @@map("core_restaurant_locations")
}

model Connection {
  connectionId        String                  @id @default(dbgenerated("gen_random_uuid()")) @map("connection_id") @db.Uuid
  restaurantId        String                  @map("restaurant_id") @db.Uuid
  foodId              String                  @map("food_id") @db.Uuid
  categories          String[]                @default([]) @db.Uuid
  foodAttributes      String[]                @default([]) @map("food_attributes") @db.Uuid
  /// SOURCE-FAITHFUL ingredient entity ids for THIS restaurant's dish (the
  /// evidence tier; canonical dish-level ingredients live on the food entity).
  ingredients         String[]                @default([]) @db.Uuid
  mentionCount        Int                     @default(0) @map("mention_count")
  totalUpvotes        Int                     @default(0) @map("total_upvotes")
  supportMentionCount Int                     @default(0) @map("support_mention_count")
  supportTotalUpvotes Int                     @default(0) @map("support_total_upvotes")
  lastMentionedAt     DateTime?               @map("last_mentioned_at")
  lastUpdated         DateTime                @default(now()) @map("last_updated")
  createdAt           DateTime                @default(now()) @map("created_at")
  food                Entity                  @relation("FoodEntity", fields: [foodId], references: [entityId])
  restaurant          Entity                  @relation("RestaurantEntity", fields: [restaurantId], references: [entityId])
  favoriteListItems   FavoriteListItem[]
  itemMentions        RestaurantItemMention[]

  photos Photo[]

  @@unique([restaurantId, foodId])
  @@index([restaurantId], map: "idx_connections_restaurant")
  @@index([foodId], map: "idx_connections_food")
  @@index([categories], map: "idx_connections_categories_gin", type: Gin)
  @@index([foodAttributes], map: "idx_connections_attributes_gin", type: Gin)
  @@index([ingredients], map: "idx_connections_ingredients_gin", type: Gin)
  @@index([mentionCount(sort: Desc)], map: "idx_connections_mention_count")
  @@index([totalUpvotes(sort: Desc)], map: "idx_connections_total_upvotes")
  @@index([lastMentionedAt(sort: Desc)], map: "idx_connections_last_mentioned")
  @@index([restaurantId, mentionCount(sort: Desc)], map: "idx_connections_restaurant_mentions")
  @@index([foodId, mentionCount(sort: Desc)], map: "idx_connections_food_mentions")
  @@index([lastUpdated(sort: Desc)], map: "idx_connections_last_updated")
  @@index([createdAt(sort: Desc)], map: "idx_connections_created_at")
  @@map("core_restaurant_items")
}

/// Derived, full-replace table: each active food's nearest dense neighbors
/// (DOC↔DOC over `core_entities.name_embedding`), precomputed offline by
/// EntitySiblingEdgeBuilderService so runtime co-inclusion is one indexed read.
/// Stores a SUPERSET (top ~30 per anchor, raw stats); the production cut
/// (cosine floor ∧ forward-rank K ∧ MUTUAL-rank R) is applied at read time from
/// env knobs so retuning needs no rebuild. `mutualRank` = the anchor's rank in
/// the SIBLING's own neighborhood (NULL = outside its top-FETCH_N ⇒ fails R).
/// No FKs by design (derived data, atomic delete+insert rebuild).
model EntitySiblingEdge {
  anchorEntityId  String   @map("anchor_entity_id") @db.Uuid
  siblingEntityId String   @map("sibling_entity_id") @db.Uuid
  cosine          Float
  forwardRank     Int      @map("forward_rank")
  mutualRank      Int?     @map("mutual_rank")
  builtAt         DateTime @default(now()) @map("built_at")

  @@id([anchorEntityId, siblingEntityId])
  @@map("derived_entity_sibling_edges")
}

/// Canonical per-FOOD category membership (directed is-a: food -> category),
/// derived by reconciling the per-connection `categories` arrays across ALL of a
/// food's connections (union, self-edges excluded, support recorded). Fixes the
/// per-mention noise where identical dishes disagreed on categories (50.5% of
/// multi-connection foods) — search resolves members from HERE (deterministic per
/// food), never from the per-connection arrays. Rebuilt full-replace after
/// projection rebuilds; support counts allow a read-time threshold if ever needed.
model FoodCategoryEdge {
  foodId      String   @map("food_id") @db.Uuid
  categoryId  String   @map("category_id") @db.Uuid
  connSupport Int      @map("conn_support")
  foodConns   Int      @map("food_conns")
  builtAt     DateTime @default(now()) @map("built_at")

  @@id([foodId, categoryId])
  @@index([categoryId], map: "idx_food_category_edges_category")
  @@map("derived_food_category_edges")
}

/// Gemini Batch API job tracking (COLLECTION_LLM_MODE=batch): a job's items
/// carry everything needed to resume the pipeline when results land — the
/// poller cron ingests via the purpose-keyed registry in GeminiBatchService.
model LlmBatchJob {
  jobId           String            @id @default(dbgenerated("gen_random_uuid()")) @map("job_id") @db.Uuid
  purpose         String            @db.VarChar(64)
  model           String            @db.VarChar(128)
  providerJobName String?           @map("provider_job_name") @db.VarChar(256)
  status          String            @default("pending") @db.VarChar(32)
  requestCount    Int               @map("request_count")
  resumeContext   Json?             @map("resume_context")
  error           String?
  ingestAttempts  Int               @default(0) @map("ingest_attempts")
  /// Lease for in-flight claims (status 'submitting'/'ingesting'): a live
  /// worker heartbeats this forward; an expired lease means the worker died
  /// and any poller may reclaim the job. NULL outside claimed states.
  leaseExpiresAt  DateTime?         @map("lease_expires_at")
  submittedAt     DateTime?         @map("submitted_at")
  completedAt     DateTime?         @map("completed_at")
  ingestedAt      DateTime?         @map("ingested_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  items           LlmBatchJobItem[]

  @@index([status], map: "idx_llm_batch_jobs_status")
  @@map("llm_batch_jobs")
}

model LlmBatchJobItem {
  jobId     String      @map("job_id") @db.Uuid
  itemIndex Int         @map("item_index")
  itemKey   String      @map("item_key") @db.VarChar(256)
  request   Json
  response  Json?
  error     String?
  job       LlmBatchJob @relation(fields: [jobId], references: [jobId], onDelete: Cascade)

  @@id([jobId, itemIndex])
  @@map("llm_batch_job_items")
}

/// Automatic per-call usage ledger for paid external APIs (Gemini + Google
/// Places). Written at the service chokepoints so every run's cost is
/// queryable later: slice by runKey/purpose/skuTier, multiply by rates.
model ApiUsageEvent {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service      String   @db.VarChar(32) // 'gemini' | 'google_places'
  operation    String   @db.VarChar(64) // e.g. 'generateContent', 'placeDetails', 'textSearch'
  skuTier      String?  @map("sku_tier") @db.VarChar(32) // Places: 'essentials'|'pro'|'enterprise'|'enterprise_atmosphere'
  model        String?  @db.VarChar(128) // Gemini model id
  mode         String?  @db.VarChar(16) // Gemini: 'interactive' | 'batch'
  inputTokens  Int?     @map("input_tokens")
  outputTokens Int?     @map("output_tokens")
  cachedTokens Int?     @map("cached_tokens")
  requestCount Int      @default(1) @map("request_count")
  caller       String   @db.VarChar(128) // logical call site, e.g. 'enrichment.placeDetails'
  runKey       String?  @map("run_key") @db.VarChar(256) // extractionRunId / batchId / jobId when known
  /// Idempotency key for at-most-once records (e.g. one row per batch job).
  /// Callers that can legitimately record multiple rows leave it null.
  dedupeKey    String?  @unique @map("dedupe_key") @db.VarChar(256)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([service, createdAt], map: "idx_api_usage_service_created")
  @@index([runKey], map: "idx_api_usage_run_key")
  @@map("api_usage_ledger")
}

/// Persisted relevance-gate verdicts (plans/archive-prefilter-pipeline.md):
/// a post judged once is never re-judged; false drops are auditable.
model CollectionRelevanceVerdict {
  platform   String   @db.VarChar(32)
  postId     String   @map("post_id") @db.VarChar(64)
  keep       Boolean
  reason     String?  @db.VarChar(256)
  model      String   @db.VarChar(128)
  promptHash String?  @map("prompt_hash") @db.VarChar(16)
  judgedAt   DateTime @default(now()) @map("judged_at")

  @@id([platform, postId])
  @@index([keep], map: "idx_relevance_verdicts_keep")
  @@map("collection_relevance_verdicts")
}

/// Persisted LLM DECISION RECORDS for calls with lasting effects whose inputs
/// are unreconstructible later (entity-match shortlists change as the DB
/// evolves; moderation verdicts get disputed). inputs+decision — NOT reasons —
/// are the replayable observability primitive; doubles as a free calibration
/// corpus from real traffic.
model LlmDecisionRecord {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kind      String   @db.VarChar(32) // 'moderation' | 'entity_match' | 'attribute_placement'
  input     Json
  decision  Json
  model     String   @db.VarChar(128)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([kind, createdAt], map: "idx_llm_decisions_kind_created")
  @@map("llm_decision_records")
}

/// ACCESS-GRANT LEDGER (plans/payments-ideal-shape.md): the single truth for
/// "does user X have entitlement Y". Every access path is a grant row —
/// trial_base, reward_photo, reward_referral, comp, promo, subscription —
/// expiresAt NULL = lifetime, revocable in one update. Redis is the
/// materialized CACHE of this ledger, never written directly by product code.
model AccessGrant {
  grantId         String    @id @default(dbgenerated("gen_random_uuid()")) @map("grant_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  entitlementCode String    @map("entitlement_code") @db.VarChar(64)
  source          String    @db.VarChar(32)
  sourceRef       String?   @map("source_ref") @db.VarChar(256)
  startsAt        DateTime  @default(now()) @map("starts_at")
  /// Absolute grants only: period end; NULL = lifetime. Day-XOR-absolute is
  /// CHECK-enforced (a grant never carries both).
  expiresAt       DateTime? @map("expires_at")
  /// Day grants only: duration of coverage, derived to wall-clock at read.
  grantedDays     Int?      @map("granted_days")
  revokedAt       DateTime? @map("revoked_at")
  revokedReason   String?   @map("revoked_reason") @db.VarChar(256)
  metadata        Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  user            User      @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, entitlementCode], map: "idx_access_grants_user_code")
  @@index([source], map: "idx_access_grants_source")
  @@index([expiresAt], map: "idx_access_grants_expires")
  @@map("access_grants")
}

/// §10 source-centric collector: durable per-(source, lane) cadence rows.
/// Lanes are ADAPTER-DECLARED per platform (reddit → chronological | keyword;
/// poll_surface → push-complete, zero pull lanes; archive is a one-shot
/// proposed sweep, never a standing lane). Lane STATE (e.g. the chronological
/// cursor) lives on the lane row — the collection_communities cursor is dead.
/// Dispatch priority = normalized lateness = (now − dueAt) ÷ tolerance (§14.3).
model SourceCollectionLane {
  sourceId              String    @map("source_id") @db.Uuid
  lane                  String    @db.VarChar(32)
  enabled               Boolean   @default(true)
  cadenceDays           Float     @map("cadence_days")
  /// §14.3 lateness tolerance — the K1 sentence "days late is fine, months is
  /// not" as a number. Chronological declares ≈ its cadence.
  latenessToleranceDays Float     @map("lateness_tolerance_days")
  dueAt                 DateTime  @default(now()) @map("due_at")
  lastRanAt             DateTime? @map("last_ran_at")
  /// Lane-kind state: chronological {lastProcessedAt}, keyword
  /// {lastTopRelevanceRunAt}. Cursor advance semantics per §10.
  state                 Json?
  /// §12.4 output-derived heartbeat: documents produced by the last due-tick
  /// plus an EWMA baseline — a lane whose output collapses vs its own
  /// baseline reads RED (legit-zero ≠ broken-zero via the baseline).
  lastOutputDocs        Int?      @map("last_output_docs")
  outputDocsBaseline    Float?    @map("output_docs_baseline")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @map("updated_at")

  @@id([sourceId, lane])
  @@index([enabled, dueAt], map: "idx_source_collection_lanes_due")
  @@map("source_collection_lanes")
}

/// §5 engines: operator-attached collection units. Territory = derived union
/// of memberPlaceIds (+ DAG descendants at read), NEVER stored. Deficiency
/// and keyword slices key off engines; scoring provenance keys off SOURCES.
model Engine {
  engineId       String   @id @default(dbgenerated("gen_random_uuid()")) @map("engine_id") @db.Uuid
  /// Stable natural key. Backfilled engines carry the legacy market_key as
  /// their name so the ask-event unmet lane keeps reading during Phase B/C.
  name           String   @unique @db.VarChar(255)
  memberPlaceIds String[] @default([]) @map("member_place_ids") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("engines")
}

/// §12.6 singleton rescorer state: collection sets dirty; ONE debounced,
/// advisory-locked rescorer owns global rebuilds (kills racing rebuilds and
/// the final-batch proxy). Single row by CHECK (id = 1).
model RescoreState {
  id            Int       @id @default(1)
  dirty         Boolean   @default(false)
  dirtySince    DateTime? @map("dirty_since")
  lastRescoreAt DateTime? @map("last_rescore_at")

  @@map("rescore_state")
}

model RestaurantItemMention {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  connectionId  String     @map("connection_id") @db.Uuid
  kind          String     @db.VarChar(16)
  mentionedAt   DateTime   @map("mentioned_at")
  sourceUpvotes Int        @default(0) @map("source_upvotes")
  /// §8 provenance unification: the document this contribution came from —
  /// the scorer resolves it to a SOURCE (the calibration room) at read.
  /// Nullable, no FK: this is a full-replace projection over evidence rows.
  sourceDocumentId String? @map("source_document_id") @db.Uuid
  connection    Connection @relation(fields: [connectionId], references: [connectionId], onDelete: Cascade)

  @@index([connectionId])
  @@map("core_restaurant_item_mentions")
}

model PublicEntityScore {
  subjectType         CraveScoreSubjectType @map("subject_type")
  subjectId           String                @map("subject_id") @db.Uuid
  scoreRunId          String                @map("score_run_id") @db.Uuid
  /// §5 scoring provenance: the SOURCE (calibration room) that contributed
  /// the dominant calibrated mass. Fame-pin territory derives from it —
  /// engine member places (derived union) when the source has an engine,
  /// else its anchor place.
  provenanceSourceId  String?               @map("provenance_source_id") @db.Uuid
  endorsementRaw      Decimal               @map("endorsement_raw") @db.Decimal(18, 6)
  percentileRank      Decimal               @map("percentile_rank") @db.Decimal(6, 5)
  displayScore        Decimal               @map("display_score") @db.Decimal(4, 2)
  // Recent-vs-baseline point surge (rawDisplayFast − rawDisplayStable); powers the
  // "↑X pts" arrow + the Rising sort. 0.001 precision so the sort tail isn't mushy.
  rising              Decimal?              @map("rising") @db.Decimal(5, 3)
  scoreVersion        String                @map("score_version") @db.VarChar(64)
  displayCurveVersion String                @map("display_curve_version") @db.VarChar(64)
  factorTrace         Json?                 @default("{}") @map("factor_trace")
  computedAt          DateTime              @default(now()) @map("computed_at") @db.Timestamptz(6)
  scoreRun            CraveScoreRun         @relation(fields: [scoreRunId], references: [scoreRunId], onDelete: Cascade)

  @@id([subjectType, subjectId])
  @@index([subjectType, displayScore(sort: Desc)], map: "idx_public_entity_scores_subject_display")
  @@index([subjectType, rising(sort: Desc)], map: "idx_public_entity_scores_subject_rising")
  @@index([scoreRunId], map: "idx_public_entity_scores_run")
  @@map("core_public_entity_scores")
}

/// §8: A_ref and A_floor are PER-LANE constants, pinned per scoreVersion
/// EPOCH — measured from the corpus once when a version first rebuilds, then
/// frozen (re-pin only with a version bump). `derivation` is the birth
/// certificate: statistic names, sample size, and the measured inputs.
model CraveScoreCalibrationEpoch {
  scoreVersion String   @map("score_version") @db.VarChar(64)
  lane         String   @db.VarChar(16)
  aRef         Float    @map("a_ref")
  aFloor       Float    @map("a_floor")
  derivation   Json     @default("{}")
  pinnedAt     DateTime @default(now()) @map("pinned_at") @db.Timestamptz(6)

  @@id([scoreVersion, lane])
  @@map("crave_score_calibration_epochs")
}

model CraveScoreRun {
  scoreRunId           String              @id @default(dbgenerated("gen_random_uuid()")) @map("score_run_id") @db.Uuid
  scoreVersion         String              @map("score_version") @db.VarChar(64)
  displayCurveVersion  String              @map("display_curve_version") @db.VarChar(64)
  displayMin           Decimal             @map("display_min") @db.Decimal(4, 2)
  displayMax           Decimal             @map("display_max") @db.Decimal(4, 2)
  status               CraveScoreRunStatus @default(running)
  recencyReferenceDate DateTime            @map("recency_reference_date") @db.Date
  startedAt            DateTime            @default(now()) @map("started_at") @db.Timestamptz(6)
