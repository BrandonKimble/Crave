/// Batch scoring trace candidate. A DB-level unique index named
/// uq_demand_scoring_candidate_scope uses NULLS NOT DISTINCT across candidate
/// identity and scope to protect createMany(skipDuplicates) trace writes.
model DemandScoringCandidate {
  candidateId          String                     @id @default(dbgenerated("gen_random_uuid()")) @map("candidate_id") @db.Uuid
  runId                String                     @map("run_id") @db.Uuid
  consumerKind         DemandScoringConsumerKind  @map("consumer_kind")
  candidateKind        String                     @map("candidate_kind") @db.VarChar(64)
  subjectKind          DemandSubjectKind          @map("subject_kind")
  subjectKey           String                     @map("subject_key") @db.VarChar(500)
  entityId             String?                    @map("entity_id") @db.Uuid
