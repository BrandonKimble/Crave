generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "darwin"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [btree_gin, pg_trgm, postgis, vector]
}

model Entity {
  entityId                            String                   @id @default(dbgenerated("gen_random_uuid()")) @map("entity_id") @db.Uuid
  name                                String                   @db.VarChar(255)
  type                                EntityType
  status                              EntityStatus             @default(active)
  canonicalDomain                     String?                  @map("canonical_domain") @db.VarChar(255)
  aliases                             String[]                 @default([])
  /// KNOWLEDGE TIER (food entities only): synthesized canonical ingredient
  /// entity ids ("al pastor taco" -> pork, pineapple, ...). World knowledge,
  /// generated per dish by the offline synthesis pass — never testimony.
  canonicalIngredients                String[]                 @default([]) @map("canonical_ingredients") @db.Uuid
  /// Stamp for the offline dish-knowledge pass (canonical ingredients +
  /// established aliases). NULL = not yet synthesized.
  knowledgeSynthesizedAt              DateTime?                @map("knowledge_synthesized_at")
  nameEmbedding                       Unsupported("vector(768)")? @map("name_embedding")
  nameEmbeddingStale                  Boolean                  @default(false) @map("name_embedding_stale")
  restaurantAttributes                String[]                 @default([]) @map("restaurant_attributes") @db.Uuid
  latitude                            Decimal?                 @db.Decimal(10, 8)
  longitude                           Decimal?                 @db.Decimal(11, 8)
  address                             String?                  @db.VarChar(500)
  restaurantMetadata                  Json?                    @map("restaurant_metadata")
  primaryLocationId                   String?                  @unique @map("primary_location_id") @db.Uuid
  lastUpdated                         DateTime                 @default(now()) @map("last_updated")
  createdAt                           DateTime                 @default(now()) @map("created_at")
  generalPraiseUpvotes                Int?                     @default(0) @map("general_praise_upvotes")
  city                                String?                  @map("city") @db.VarChar(255)
  region                              String?                  @map("region") @db.VarChar(255)
  country                             String?                  @map("country") @db.VarChar(2)
  postalCode                          String?                  @map("postal_code") @db.VarChar(32)
  priceLevel                          Int?                     @map("price_level")
  priceLevelUpdatedAt                 DateTime?                @map("price_level_updated_at")
  lastPolledAt                        DateTime?                @map("last_polled_at")
  foodConnections                     Connection[]             @relation("FoodEntity")
  restaurantConnections               Connection[]             @relation("RestaurantEntity")
  onDemandRequests                    OnDemandRequest[]
  favoriteEvents                      UserFavoriteEvent[]
  pollTopicDishTargets                PollTopic[]              @relation("PollTopicTargetDish")
  pollTopicRestaurantTargets          PollTopic[]              @relation("PollTopicTargetRestaurant")
  pollTopicFoodAttributeTargets       PollTopic[]              @relation("PollTopicTargetFoodAttribute")
  pollTopicRestaurantAttributeTargets PollTopic[]              @relation("PollTopicTargetRestaurantAttribute")
  searchEventEntities                 SearchEventEntity[]
  userFavorites                       UserFavorite[]
  favoriteListItems                   FavoriteListItem[]
  restaurantViews                     RestaurantView[]
  foodViews                           FoodView[]
  viewEvents                          UserEntityViewEvent[]    @relation("ViewedEntity")
  viewContextEvents                   UserEntityViewEvent[]    @relation("ViewContextRestaurant")
  searchDemandDailyRows               UserSearchDemandDaily[]
  demandScoringCandidates             DemandScoringCandidate[]
  locations                           RestaurantLocation[]     @relation("RestaurantLocations")
  marketPresences                     EntityMarketPresence[]
  restaurantEvents                    RestaurantEvent[]        @relation("RestaurantEventRestaurant")
  restaurantEntityEvents              RestaurantEntityEvent[]  @relation("RestaurantEntityEventRestaurant")
  restaurantEntityEventTargets        RestaurantEntityEvent[]  @relation("RestaurantEntityEventTarget")
  restaurantEntitySignals             RestaurantEntitySignal[] @relation("RestaurantEntitySignalRestaurant")
  restaurantEntitySignalTargets       RestaurantEntitySignal[] @relation("RestaurantEntitySignalTarget")
  primaryLocation                     RestaurantLocation?      @relation("PrimaryLocation", fields: [primaryLocationId], references: [locationId])
  onDemandAskEvents                   OnDemandAskEvent[]

  @@index([type], map: "idx_entities_type")
  @@index([type, status], map: "idx_entities_type_status")
  @@index([name], map: "idx_entities_name")
  @@index([canonicalDomain], map: "idx_entities_canonical_domain")
  @@index([type, canonicalDomain], map: "idx_entities_type_canonical_domain")
  @@index([aliases], map: "idx_entities_aliases")
  @@index([canonicalIngredients], map: "idx_entities_canonical_ingredients_gin", type: Gin)
  @@index([restaurantAttributes], map: "idx_entities_restaurant_attributes")
  @@index([longitude, latitude], map: "idx_entities_location")
  @@index([address], map: "idx_entities_address")
  @@index([city], map: "idx_entities_city")
  @@index([region], map: "idx_entities_region")
  @@index([country], map: "idx_entities_country")
  @@index([priceLevel], map: "idx_entities_price_level")
  @@index([lastPolledAt], map: "idx_entities_last_polled_at")
  @@index([primaryLocationId], map: "idx_entities_primary_location")
  @@index([lastUpdated(sort: Desc)], map: "idx_entities_last_updated")
  @@index([createdAt(sort: Desc)], map: "idx_entities_created_at")
  @@map("core_entities")
}

model EntityMarketPresence {
  entityId  String   @map("entity_id") @db.Uuid
  marketKey String   @map("market_key") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  entity    Entity   @relation(fields: [entityId], references: [entityId], onDelete: Cascade)

  @@id([entityId, marketKey])
  @@index([marketKey], map: "idx_entity_market_presence_market_key")
  @@index([entityId], map: "idx_entity_market_presence_entity_id")
  @@map("core_entity_market_presence")
}

model RestaurantLocation {
  locationId       String    @id @default(dbgenerated("gen_random_uuid()")) @map("location_id") @db.Uuid
  restaurantId     String    @map("restaurant_id") @db.Uuid
  googlePlaceId    String?   @unique @map("google_place_id") @db.VarChar(255)
  latitude         Decimal?  @db.Decimal(10, 8)
  longitude        Decimal?  @db.Decimal(11, 8)
  address          String?   @db.VarChar(500)
  city             String?   @db.VarChar(255)
  region           String?   @db.VarChar(255)
  country          String?   @db.VarChar(2)
  postalCode       String?   @map("postal_code") @db.VarChar(32)
  phoneNumber      String?   @map("phone_number") @db.VarChar(64)
  websiteUrl       String?   @map("website_url") @db.VarChar(2048)
  websiteDomain    String?   @map("website_domain") @db.VarChar(255)
  hours            Json?     @map("hours")
  utcOffsetMinutes Int?      @map("utc_offset_minutes")
  timeZone         String?   @map("time_zone") @db.VarChar(64)
  isPrimary        Boolean   @default(false) @map("is_primary")
  lastPolledAt     DateTime? @map("last_polled_at")
  /// Google businessStatus from the last refresh poll (CLOSED_PERMANENTLY etc.);
  /// written by refreshStaleLocations, acted on by the janitor.
  businessStatus   String?   @map("business_status") @db.VarChar(32)
  movedPlaceId     String?   @map("moved_place_id") @db.VarChar(255)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @map("updated_at")
  restaurant       Entity    @relation("RestaurantLocations", fields: [restaurantId], references: [entityId], onDelete: Cascade)
  primaryFor       Entity?   @relation("PrimaryLocation")

  @@index([restaurantId], map: "idx_restaurant_locations_restaurant")
  @@index([restaurantId, isPrimary], map: "idx_restaurant_locations_primary")
  @@index([restaurantId, websiteDomain], map: "idx_restaurant_locations_restaurant_domain")
  @@index([longitude, latitude], map: "idx_restaurant_locations_location")
  @@index([googlePlaceId], map: "idx_restaurant_locations_google_place_id")
  @@index([websiteDomain], map: "idx_restaurant_locations_website_domain")
  @@map("core_restaurant_locations")
}

model Connection {
  connectionId               String                @id @default(dbgenerated("gen_random_uuid()")) @map("connection_id") @db.Uuid
  restaurantId               String                @map("restaurant_id") @db.Uuid
  foodId                     String                @map("food_id") @db.Uuid
  categories                 String[]              @default([]) @db.Uuid
  foodAttributes             String[]              @default([]) @map("food_attributes") @db.Uuid
  /// SOURCE-FAITHFUL ingredient entity ids for THIS restaurant's dish (the
  /// evidence tier; canonical dish-level ingredients live on the food entity).
  ingredients                String[]              @default([]) @db.Uuid
  mentionCount               Int                   @default(0) @map("mention_count")
  totalUpvotes               Int                   @default(0) @map("total_upvotes")
  supportMentionCount        Int                   @default(0) @map("support_mention_count")
  supportTotalUpvotes        Int                   @default(0) @map("support_total_upvotes")
  lastMentionedAt            DateTime?             @map("last_mentioned_at")
  lastUpdated                DateTime              @default(now()) @map("last_updated")
  createdAt                  DateTime              @default(now()) @map("created_at")
  food                       Entity                @relation("FoodEntity", fields: [foodId], references: [entityId])
  restaurant                 Entity                @relation("RestaurantEntity", fields: [restaurantId], references: [entityId])
  favoriteListItems          FavoriteListItem[]
  FoodView                   FoodView[]
  itemMentions               RestaurantItemMention[]
  viewEvents                 UserEntityViewEvent[]

  @@unique([restaurantId, foodId])
  @@index([restaurantId], map: "idx_connections_restaurant")
  @@index([foodId], map: "idx_connections_food")
  @@index([categories], map: "idx_connections_categories_gin", type: Gin)
  @@index([foodAttributes], map: "idx_connections_attributes_gin", type: Gin)
  @@index([ingredients], map: "idx_connections_ingredients_gin", type: Gin)
  @@index([mentionCount(sort: Desc)], map: "idx_connections_mention_count")
  @@index([totalUpvotes(sort: Desc)], map: "idx_connections_total_upvotes")
  @@index([lastMentionedAt(sort: Desc)], map: "idx_connections_last_mentioned")
  @@index([restaurantId, mentionCount(sort: Desc)], map: "idx_connections_restaurant_mentions")
  @@index([foodId, mentionCount(sort: Desc)], map: "idx_connections_food_mentions")
  @@index([lastUpdated(sort: Desc)], map: "idx_connections_last_updated")
  @@index([createdAt(sort: Desc)], map: "idx_connections_created_at")
  @@map("core_restaurant_items")
}

/// Derived, full-replace table: each active food's nearest dense neighbors
/// (DOC↔DOC over `core_entities.name_embedding`), precomputed offline by
/// EntitySiblingEdgeBuilderService so runtime co-inclusion is one indexed read.
/// Stores a SUPERSET (top ~30 per anchor, raw stats); the production cut
/// (cosine floor ∧ forward-rank K ∧ MUTUAL-rank R) is applied at read time from
/// env knobs so retuning needs no rebuild. `mutualRank` = the anchor's rank in
/// the SIBLING's own neighborhood (NULL = outside its top-FETCH_N ⇒ fails R).
/// No FKs by design (derived data, atomic delete+insert rebuild).
model EntitySiblingEdge {
  anchorEntityId  String   @map("anchor_entity_id") @db.Uuid
  siblingEntityId String   @map("sibling_entity_id") @db.Uuid
  cosine          Float
  forwardRank     Int      @map("forward_rank")
  mutualRank      Int?     @map("mutual_rank")
  builtAt         DateTime @default(now()) @map("built_at")

  @@id([anchorEntityId, siblingEntityId])
  @@map("derived_entity_sibling_edges")
}

/// Canonical per-FOOD category membership (directed is-a: food -> category),
/// derived by reconciling the per-connection `categories` arrays across ALL of a
/// food's connections (union, self-edges excluded, support recorded). Fixes the
/// per-mention noise where identical dishes disagreed on categories (50.5% of
/// multi-connection foods) — search resolves members from HERE (deterministic per
/// food), never from the per-connection arrays. Rebuilt full-replace after
/// projection rebuilds; support counts allow a read-time threshold if ever needed.
model FoodCategoryEdge {
  foodId      String   @map("food_id") @db.Uuid
  categoryId  String   @map("category_id") @db.Uuid
  connSupport Int      @map("conn_support")
  foodConns   Int      @map("food_conns")
  builtAt     DateTime @default(now()) @map("built_at")

  @@id([foodId, categoryId])
  @@index([categoryId], map: "idx_food_category_edges_category")
  @@map("derived_food_category_edges")
}

/// Gemini Batch API job tracking (COLLECTION_LLM_MODE=batch): a job's items
/// carry everything needed to resume the pipeline when results land — the
/// poller cron ingests via the purpose-keyed registry in GeminiBatchService.
model LlmBatchJob {
  jobId           String    @id @default(dbgenerated("gen_random_uuid()")) @map("job_id") @db.Uuid
  purpose         String    @db.VarChar(64)
  model           String    @db.VarChar(128)
  providerJobName String?   @map("provider_job_name") @db.VarChar(256)
  status          String    @default("pending") @db.VarChar(32)
  requestCount    Int       @map("request_count")
  resumeContext   Json?     @map("resume_context")
  error           String?
  submittedAt     DateTime? @map("submitted_at")
  completedAt     DateTime? @map("completed_at")
  ingestedAt      DateTime? @map("ingested_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  items           LlmBatchJobItem[]

  @@index([status], map: "idx_llm_batch_jobs_status")
  @@map("llm_batch_jobs")
}

model LlmBatchJobItem {
  jobId     String  @map("job_id") @db.Uuid
  itemIndex Int     @map("item_index")
  itemKey   String  @map("item_key") @db.VarChar(256)
  request   Json
  response  Json?
  error     String?
  job       LlmBatchJob @relation(fields: [jobId], references: [jobId], onDelete: Cascade)

  @@id([jobId, itemIndex])
  @@map("llm_batch_job_items")
}

/// Automatic per-call usage ledger for paid external APIs (Gemini + Google
/// Places). Written at the service chokepoints so every run's cost is
/// queryable later: slice by runKey/purpose/skuTier, multiply by rates.
model ApiUsageEvent {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service      String   @db.VarChar(32) // 'gemini' | 'google_places'
  operation    String   @db.VarChar(64) // e.g. 'generateContent', 'placeDetails', 'textSearch'
  skuTier      String?  @map("sku_tier") @db.VarChar(32) // Places: 'essentials'|'pro'|'enterprise'|'enterprise_atmosphere'
  model        String?  @db.VarChar(128) // Gemini model id
  mode         String?  @db.VarChar(16) // Gemini: 'interactive' | 'batch'
  inputTokens  Int?     @map("input_tokens")
  outputTokens Int?     @map("output_tokens")
  cachedTokens Int?     @map("cached_tokens")
  requestCount Int      @default(1) @map("request_count")
  caller       String   @db.VarChar(128) // logical call site, e.g. 'enrichment.placeDetails'
  runKey       String?  @map("run_key") @db.VarChar(256) // extractionRunId / batchId / jobId when known
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([service, createdAt], map: "idx_api_usage_service_created")
  @@index([runKey], map: "idx_api_usage_run_key")
  @@map("api_usage_ledger")
}

/// Persisted relevance-gate verdicts (plans/archive-prefilter-pipeline.md):
/// a post judged once is never re-judged; false drops are auditable.
model CollectionRelevanceVerdict {
  platform String   @db.VarChar(32)
  postId   String   @map("post_id") @db.VarChar(64)
  keep     Boolean
  reason   String?  @db.VarChar(256)
  model      String   @db.VarChar(128)
  promptHash String?  @map("prompt_hash") @db.VarChar(16)
  judgedAt   DateTime @default(now()) @map("judged_at")

  @@id([platform, postId])
  @@index([keep], map: "idx_relevance_verdicts_keep")
  @@map("collection_relevance_verdicts")
}

model RestaurantItemMention {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  connectionId  String     @map("connection_id") @db.Uuid
  kind          String     @db.VarChar(16)
  mentionedAt   DateTime   @map("mentioned_at")
  sourceUpvotes Int        @default(0) @map("source_upvotes")
  connection    Connection @relation(fields: [connectionId], references: [connectionId], onDelete: Cascade)

  @@index([connectionId])
  @@map("core_restaurant_item_mentions")
}

model PublicEntityScore {
  subjectType         CraveScoreSubjectType   @map("subject_type")
  subjectId           String                  @map("subject_id") @db.Uuid
  scoreRunId          String                  @map("score_run_id") @db.Uuid
  scoringMarketKey    String?                 @map("scoring_market_key") @db.VarChar(255)
  endorsementRaw      Decimal                 @map("endorsement_raw") @db.Decimal(18, 6)
  percentileRank      Decimal                 @map("percentile_rank") @db.Decimal(6, 5)
  displayScore        Decimal                 @map("display_score") @db.Decimal(4, 2)
  // Recent-vs-baseline point surge (rawDisplayFast − rawDisplayStable); powers the
  // "↑X pts" arrow + the Rising sort. 0.001 precision so the sort tail isn't mushy.
  rising              Decimal?                @map("rising") @db.Decimal(5, 3)
  scoreVersion        String                  @map("score_version") @db.VarChar(64)
  displayCurveVersion String                  @map("display_curve_version") @db.VarChar(64)
  factorTrace         Json?                   @default("{}") @map("factor_trace")
  computedAt          DateTime                @default(now()) @map("computed_at") @db.Timestamptz(6)
  scoreRun            CraveScoreRun           @relation(fields: [scoreRunId], references: [scoreRunId], onDelete: Cascade)

  @@id([subjectType, subjectId])
  @@index([subjectType, displayScore(sort: Desc)], map: "idx_public_entity_scores_subject_display")
  @@index([scoringMarketKey, subjectType, displayScore(sort: Desc)], map: "idx_public_entity_scores_market_subject_display")
  @@index([subjectType, rising(sort: Desc)], map: "idx_public_entity_scores_subject_rising")
  @@index([scoreRunId], map: "idx_public_entity_scores_run")
  @@map("core_public_entity_scores")
}

model CraveScoreRun {
  scoreRunId           String                     @id @default(dbgenerated("gen_random_uuid()")) @map("score_run_id") @db.Uuid
  scoreVersion         String                     @map("score_version") @db.VarChar(64)
  displayCurveVersion  String                     @map("display_curve_version") @db.VarChar(64)
  displayMin           Decimal                    @map("display_min") @db.Decimal(4, 2)
  displayMax           Decimal                    @map("display_max") @db.Decimal(4, 2)
  status               CraveScoreRunStatus        @default(running)
  recencyReferenceDate DateTime                   @map("recency_reference_date") @db.Date
  startedAt            DateTime                   @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt          DateTime?                  @map("completed_at") @db.Timestamptz(6)
  inputCounts          Json?                      @default("{}") @map("input_counts")
  configSnapshot       Json?                      @default("{}") @map("config_snapshot")
  errorMessage         String?                    @map("error_message")
  scores               PublicEntityScore[]

  @@index([scoreVersion, startedAt(sort: Desc)], map: "idx_crave_score_runs_version_started")
  @@index([status, startedAt(sort: Desc)], map: "idx_crave_score_runs_status_started")
  @@map("core_crave_score_runs")
}

model ProcessedSource {
  pipeline    String   @db.VarChar(32)
  sourceId    String   @map("source_id") @db.VarChar(64)
  community   String?  @db.VarChar(100)
  processedAt DateTime @default(now()) @map("processed_at")

  @@id([pipeline, sourceId])
  @@index([pipeline], map: "idx_processed_source_pipeline")
  @@index([community], map: "idx_processed_source_community")
  @@index([processedAt(sort: Desc)], map: "idx_processed_source_processed_at")
  @@map("collection_processed_sources")
}

model SourceDocument {
  documentId             String                    @id @default(dbgenerated("gen_random_uuid()")) @map("document_id") @db.Uuid
  platform               String                    @default("reddit") @db.VarChar(32)
  community              String?                   @db.VarChar(100)
  sourceType             MentionSource             @map("source_type")
  sourceId               String                    @map("source_id") @db.VarChar(64)
  parentSourceId         String?                   @map("parent_source_id") @db.VarChar(64)
  title                  String?                   @db.Text
  body                   String?                   @db.Text
  url                    String?                   @db.VarChar(2048)
  sourceCreatedAt        DateTime                  @map("source_created_at")
  collectedAt            DateTime                  @default(now()) @map("collected_at")
  scoreSnapshot          Int?                      @map("score_snapshot")
  rawPayload             Json?                     @map("raw_payload")
  activeExtractionRunId  String?                   @map("active_extraction_run_id") @db.Uuid
  activeExtractionRun    ExtractionRun?            @relation("ActiveExtractionRunDocuments", fields: [activeExtractionRunId], references: [extractionRunId], onDelete: SetNull)
  extractionInputs       ExtractionInputDocument[]
  restaurantEvents       RestaurantEvent[]
  restaurantEntityEvents RestaurantEntityEvent[]

  @@unique([platform, sourceType, sourceId], map: "source_documents_platform_type_source_id_key")
  @@index([community], map: "idx_source_documents_community")
  @@index([sourceCreatedAt(sort: Desc)], map: "idx_source_documents_created_at")
  @@index([activeExtractionRunId], map: "idx_source_documents_active_run")
  @@map("collection_source_documents")
}

model CollectionRun {
  collectionRunId String          @id @default(dbgenerated("gen_random_uuid()")) @map("collection_run_id") @db.Uuid
  scopeKey        String          @unique @map("scope_key") @db.VarChar(255)
  pipeline        String          @db.VarChar(32)
  platform        String?         @db.VarChar(32)
  community       String?         @db.VarChar(255)
  status          String          @db.VarChar(32)
  startedAt       DateTime        @default(now()) @map("started_at")
  completedAt     DateTime?       @map("completed_at")
  metadata        Json?           @default("{}")
  extractionRuns  ExtractionRun[]

  @@index([pipeline, startedAt(sort: Desc)], map: "idx_collection_runs_pipeline_started_at")
  @@index([status], map: "idx_collection_runs_status")
  @@map("collection_runs")
}

model ExtractionRun {
  extractionRunId         String                  @id @default(dbgenerated("gen_random_uuid()")) @map("extraction_run_id") @db.Uuid
  collectionRunId         String?                 @map("collection_run_id") @db.Uuid
  pipeline                String                  @db.VarChar(32)
  model                   String                  @db.VarChar(128)
  systemPromptHash        String                  @map("system_prompt_hash") @db.VarChar(64)
  systemPrompt            String                  @map("system_prompt") @db.Text
  generationConfig        Json                    @default("{}") @map("generation_config")
  chunkingConfig          Json                    @default("{}") @map("chunking_config")
  extractionSchemaVersion String                  @default("v1") @map("extraction_schema_version") @db.VarChar(32)
  status                  String                  @db.VarChar(32)
  startedAt               DateTime                @default(now()) @map("started_at")
  completedAt             DateTime?               @map("completed_at")
  metadata                Json?                   @default("{}")
  collectionRun           CollectionRun?          @relation(fields: [collectionRunId], references: [collectionRunId], onDelete: SetNull)
  inputs                  ExtractionInput[]
  activeForDocuments      SourceDocument[]        @relation("ActiveExtractionRunDocuments")
  restaurantEvents        RestaurantEvent[]
  restaurantEntityEvents  RestaurantEntityEvent[]

  @@index([pipeline, startedAt(sort: Desc)], map: "idx_extraction_runs_pipeline_started_at")
  @@index([collectionRunId], map: "idx_extraction_runs_collection_run_id")
  @@index([status], map: "idx_extraction_runs_status")
  @@map("collection_extraction_runs")
}

model ExtractionInput {
  inputId                String                    @id @default(dbgenerated("gen_random_uuid()")) @map("input_id") @db.Uuid
  extractionRunId        String                    @map("extraction_run_id") @db.Uuid
  inputIndex             Int                       @map("input_index")
  inputPayload           Json                      @map("input_payload")
  sourceMap              Json?                     @map("source_map")
  rawOutput              Json?                     @map("raw_output")
  createdAt              DateTime                  @default(now()) @map("created_at")
  extractionRun          ExtractionRun             @relation(fields: [extractionRunId], references: [extractionRunId], onDelete: Cascade)
  sourceDocuments        ExtractionInputDocument[]
  restaurantEvents       RestaurantEvent[]
  restaurantEntityEvents RestaurantEntityEvent[]

  @@unique([extractionRunId, inputIndex], map: "extraction_inputs_run_index_key")
  @@index([extractionRunId], map: "idx_extraction_inputs_run")
  @@map("collection_extraction_inputs")
}

model ExtractionInputDocument {
  inputId    String          @map("input_id") @db.Uuid
  documentId String          @map("document_id") @db.Uuid
  ordinal    Int
  input      ExtractionInput @relation(fields: [inputId], references: [inputId], onDelete: Cascade)
  document   SourceDocument  @relation(fields: [documentId], references: [documentId], onDelete: Cascade)

  @@id([inputId, documentId])
  @@index([documentId], map: "idx_extraction_input_documents_document")
  @@index([inputId, ordinal], map: "idx_extraction_input_documents_input_ordinal")
  @@map("collection_extraction_input_documents")
}

model RestaurantEvent {
  eventId          String          @id @default(dbgenerated("gen_random_uuid()")) @map("event_id") @db.Uuid
  extractionRunId  String          @map("extraction_run_id") @db.Uuid
  inputId          String          @map("input_id") @db.Uuid
  sourceDocumentId String          @map("source_document_id") @db.Uuid
  restaurantId     String          @map("restaurant_id") @db.Uuid
  mentionKey       String          @map("mention_key") @db.VarChar(255)
  evidenceType     String          @map("evidence_type") @db.VarChar(64)
  mentionedAt      DateTime        @map("mentioned_at")
  sourceUpvotes    Int             @default(0) @map("source_upvotes")
  metadata         Json?           @default("{}")
  createdAt        DateTime        @default(now()) @map("created_at")
  extractionRun    ExtractionRun   @relation(fields: [extractionRunId], references: [extractionRunId], onDelete: Cascade)
  input            ExtractionInput @relation(fields: [inputId], references: [inputId], onDelete: Cascade)
  sourceDocument   SourceDocument  @relation(fields: [sourceDocumentId], references: [documentId], onDelete: Cascade)
  restaurant       Entity          @relation("RestaurantEventRestaurant", fields: [restaurantId], references: [entityId], onDelete: Cascade)

  @@unique([extractionRunId, mentionKey, restaurantId, evidenceType], map: "restaurant_events_run_mention_restaurant_type_key")
  @@index([restaurantId, mentionedAt(sort: Desc)], map: "idx_restaurant_events_restaurant_time")
  @@index([sourceDocumentId], map: "idx_restaurant_events_source_document")
  @@index([extractionRunId], map: "idx_restaurant_events_run")
  @@map("core_restaurant_events")
}

model RestaurantEntityEvent {
  eventId          String          @id @default(dbgenerated("gen_random_uuid()")) @map("event_id") @db.Uuid
  extractionRunId  String          @map("extraction_run_id") @db.Uuid
  inputId          String          @map("input_id") @db.Uuid
  sourceDocumentId String          @map("source_document_id") @db.Uuid
  restaurantId     String          @map("restaurant_id") @db.Uuid
  mentionKey       String          @map("mention_key") @db.VarChar(255)
  entityId         String          @map("entity_id") @db.Uuid
  entityType       EntityType      @map("entity_type")
  evidenceType     String          @map("evidence_type") @db.VarChar(64)
  isMenuItem       Boolean?        @map("is_menu_item")
  mentionedAt      DateTime        @map("mentioned_at")
  sourceUpvotes    Int             @default(0) @map("source_upvotes")
  metadata         Json?           @default("{}")
  createdAt        DateTime        @default(now()) @map("created_at")
  extractionRun    ExtractionRun   @relation(fields: [extractionRunId], references: [extractionRunId], onDelete: Cascade)
  input            ExtractionInput @relation(fields: [inputId], references: [inputId], onDelete: Cascade)
  sourceDocument   SourceDocument  @relation(fields: [sourceDocumentId], references: [documentId], onDelete: Cascade)
  restaurant       Entity          @relation("RestaurantEntityEventRestaurant", fields: [restaurantId], references: [entityId], onDelete: Cascade)
  entity           Entity          @relation("RestaurantEntityEventTarget", fields: [entityId], references: [entityId], onDelete: Cascade)

  @@unique([extractionRunId, mentionKey, restaurantId, entityId, evidenceType], map: "restaurant_entity_events_run_mention_restaurant_entity_type_key")
  @@index([restaurantId, mentionedAt(sort: Desc)], map: "idx_restaurant_entity_events_restaurant_time")
  @@index([entityId, mentionedAt(sort: Desc)], map: "idx_restaurant_entity_events_entity_time")
  @@index([sourceDocumentId], map: "idx_restaurant_entity_events_source_document")
  @@index([extractionRunId], map: "idx_restaurant_entity_events_run")
  @@map("core_restaurant_entity_events")
}

model RestaurantEntitySignal {
  restaurantId String     @map("restaurant_id") @db.Uuid
  entityId     String     @map("entity_id") @db.Uuid
  entityType   EntityType @map("entity_type")
  mentionCount Int        @default(0) @map("mention_count")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  restaurant   Entity     @relation("RestaurantEntitySignalRestaurant", fields: [restaurantId], references: [entityId], onDelete: Cascade)
  entity       Entity     @relation("RestaurantEntitySignalTarget", fields: [entityId], references: [entityId], onDelete: Cascade)

  @@id([restaurantId, entityId])
  @@index([entityId, mentionCount(sort: Desc)], map: "idx_restaurant_entity_signals_entity_mentions")
  @@index([restaurantId, mentionCount(sort: Desc)], map: "idx_restaurant_entity_signals_restaurant_mentions")
  @@index([restaurantId, entityType, mentionCount(sort: Desc)], map: "idx_restaurant_entity_signals_restaurant_type_mentions")
  @@map("core_restaurant_entity_signals")
}

model PollTopic {
  topicId                     String          @id @default(dbgenerated("gen_random_uuid()")) @map("topic_id") @db.Uuid
  title                       String          @db.VarChar(255)
  description                 String?         @db.VarChar(500)
  marketKey                   String?         @map("market_key") @db.VarChar(255)
  region                      String?         @db.VarChar(255)
  country                     String?         @db.VarChar(2)
  categoryEntityIds           String[]        @default([]) @map("category_entity_ids") @db.Uuid
  seedEntityIds               String[]        @default([]) @map("seed_entity_ids") @db.Uuid
  status                      PollTopicStatus @default(draft)
  metadata                    Json?           @default("{}")
  createdByUserId             String?         @map("created_by_user_id") @db.Uuid
  createdAt                   DateTime        @default(now()) @map("created_at")
  updatedAt                   DateTime        @updatedAt @map("updated_at")
  targetDishId                String?         @map("target_dish_id") @db.Uuid
  targetRestaurantId          String?         @map("target_restaurant_id") @db.Uuid
  targetFoodAttributeId       String?         @map("target_food_attribute_id") @db.Uuid
  targetRestaurantAttributeId String?         @map("target_restaurant_attribute_id") @db.Uuid
  topicType                   PollTopicType   @default(best_dish) @map("topic_type")
  targetDish                  Entity?         @relation("PollTopicTargetDish", fields: [targetDishId], references: [entityId])
  targetRestaurant            Entity?         @relation("PollTopicTargetRestaurant", fields: [targetRestaurantId], references: [entityId])
  targetFoodAttribute         Entity?         @relation("PollTopicTargetFoodAttribute", fields: [targetFoodAttributeId], references: [entityId])
  targetRestaurantAttribute   Entity?         @relation("PollTopicTargetRestaurantAttribute", fields: [targetRestaurantAttributeId], references: [entityId])
  polls                       Poll[]

  @@index([marketKey], map: "idx_poll_topics_market_key")
  @@index([createdByUserId], map: "idx_poll_topics_created_by_user")
  @@index([status], map: "idx_poll_topics_status")
  @@map("poll_topics")
}

model Poll {
  pollId             String       @id @default(dbgenerated("gen_random_uuid()")) @map("poll_id") @db.Uuid
  topicId            String?      @map("topic_id") @db.Uuid
  question           String       @db.VarChar(500)
  state              PollState    @default(draft)
  origin             PollOrigin   @default(user)
  mode               PollMode     @default(ranked)
  axis               Json?
  marketKey          String?      @map("market_key") @db.VarChar(255)
  region             String?      @db.VarChar(255)
  scheduledFor       DateTime?    @map("scheduled_for")
  launchedAt         DateTime?    @map("launched_at")
  closedAt           DateTime?    @map("closed_at")
  graduatedAt        DateTime?    @map("graduated_at")
  allowUserAdditions Boolean      @default(true) @map("allow_user_additions")
  audienceFilters    Json?        @map("audience_filters")
  metadata           Json?        @default("{}")
  createdByUserId    String?      @map("created_by_user_id") @db.Uuid
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  comments           PollComment[]
  leaderboardEntries PollLeaderboardEntry[]
  endorsements       PollEndorsement[]
  topic              PollTopic?   @relation(fields: [topicId], references: [topicId], onDelete: Cascade)

  @@index([topicId], map: "idx_polls_topic_id")
  @@index([state], map: "idx_polls_state")
  @@index([marketKey], map: "idx_polls_market_key")
  @@index([createdByUserId], map: "idx_polls_created_by_user")
  @@index([scheduledFor], map: "idx_polls_scheduled_for")
  @@map("polls")
}

/// The discussion-thread spine (Phase 2 schema; CRUD + sort land in Phase 4).
/// A poll comment is the primary unit — the leaderboard is projected over these.
model PollComment {
  commentId        String                      @id @default(dbgenerated("gen_random_uuid()")) @map("comment_id") @db.Uuid
  pollId           String                      @map("poll_id") @db.Uuid
  userId           String                      @map("user_id") @db.Uuid
  parentCommentId  String?                     @map("parent_comment_id") @db.Uuid
  body             String                      @db.Text
  score            Int                         @default(0)
  publicId         String                      @unique @map("public_id") @db.VarChar(32)
  moderationStatus PollCommentModerationStatus @default(pending) @map("moderation_status")
  extractionStatus PollCommentExtractionStatus @default(pending) @map("extraction_status")
  entitySpans      Json?                       @map("entity_spans")
  loggedAt         DateTime                    @default(now()) @map("logged_at")
  editedAt         DateTime?                   @map("edited_at")
  deletedAt        DateTime?                   @map("deleted_at")
  poll             Poll                        @relation(fields: [pollId], references: [pollId], onDelete: Cascade)
  user             User                        @relation(fields: [userId], references: [userId], onDelete: Cascade)
  parent           PollComment?                @relation("PollCommentThread", fields: [parentCommentId], references: [commentId], onDelete: NoAction, onUpdate: NoAction)
  children         PollComment[]               @relation("PollCommentThread")
  likes            PollCommentLike[]

  @@index([pollId, score(sort: Desc)], map: "idx_poll_comments_poll_score")
  @@index([pollId, loggedAt(sort: Desc)], map: "idx_poll_comments_poll_logged")
  @@index([parentCommentId], map: "idx_poll_comments_parent")
  @@index([userId], map: "idx_poll_comments_user")
  @@map("poll_comments")
}

/// Reddit-style per-comment likes (drive thread sort + endorsement signal).
model PollCommentLike {
  commentId String      @map("comment_id") @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  loggedAt  DateTime    @default(now()) @map("logged_at")
  comment   PollComment @relation(fields: [commentId], references: [commentId], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([commentId, userId])
  @@index([commentId], map: "idx_poll_comment_likes_comment")
  @@index([userId], map: "idx_poll_comment_likes_user")
  @@map("poll_comment_likes")
}

/// Leaderboard projection (Phase 2 schema; Phase 4 fills it). Subject = a
/// restaurant entity OR a restaurant+dish Connection, mirroring Crave-Score subjects.
/// Rebuilt on interaction + authoritatively at close; never a vote table of record.
model PollLeaderboardEntry {
  pollId            String                     @map("poll_id") @db.Uuid
  subjectType       PollLeaderboardSubjectType @map("subject_type")
  // Either an entity UUID (restaurant-axis) or a poll-local "restaurantId::foodId"
  // composite (dish-axis) — so it's a plain string, not a UUID column.
  subjectId         String                     @map("subject_id")
  distinctEndorsers Int                        @default(0) @map("distinct_endorsers")
  score             Decimal                    @default(0) @db.Decimal(18, 6)
  rank              Int                        @default(0)
  updatedAt         DateTime                   @updatedAt @map("updated_at")
  poll              Poll                       @relation(fields: [pollId], references: [pollId], onDelete: Cascade)

  @@id([pollId, subjectType, subjectId])
  @@index([pollId, rank], map: "idx_poll_leaderboard_poll_rank")
  @@map("poll_leaderboard_entries")
}

/// A user's direct endorsement of a leaderboard subject within a poll — the §13A
/// public "endorse" (like) signal applied per-candidate, powering tap-to-endorse on
/// the poll bars. One row per (poll, subject, user); toggled on/off; folded into
/// PollLeaderboardEntry.distinctEndorsers alongside comment-derived endorsers.
model PollEndorsement {
  pollId      String                     @map("poll_id") @db.Uuid
  subjectType PollLeaderboardSubjectType @map("subject_type")
  // Either an entity UUID (restaurant-axis) or a poll-local "restaurantId::foodId"
  // composite (dish-axis) — a plain string, not a UUID column.
  subjectId   String                     @map("subject_id")
  userId      String                     @map("user_id") @db.Uuid
  createdAt   DateTime                   @default(now()) @map("created_at")
  poll        Poll                       @relation(fields: [pollId], references: [pollId], onDelete: Cascade)
  user        User                       @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([pollId, subjectType, subjectId, userId])
  @@index([pollId, subjectType, subjectId], map: "idx_poll_endorsement_subject")
  @@index([userId], map: "idx_poll_endorsement_user")
  @@map("poll_endorsements")
}

model NotificationDevice {
  deviceId      String               @id @default(dbgenerated("gen_random_uuid()")) @map("device_id") @db.Uuid
  userId        String?              @map("user_id") @db.VarChar(255)
  expoPushToken String               @unique @map("expo_push_token") @db.VarChar(255)
  provider      NotificationProvider @default(expo)
  platform      String?              @db.VarChar(50)
  appVersion    String?              @map("app_version") @db.VarChar(32)
  locale        String?              @db.VarChar(16)
  city          String?              @db.VarChar(255)
  metadata      Json?                @default("{}")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  notifications Notification[]

  @@index([userId], map: "idx_notification_devices_user_id")
  @@index([city], map: "idx_notification_devices_city")
  @@map("notification_devices")
}

model Notification {
  notificationId String              @id @default(dbgenerated("gen_random_uuid()")) @map("notification_id") @db.Uuid
  type           NotificationType    @map("notification_type")
  status         NotificationStatus  @default(pending) @map("status")
  payload        Json?               @default("{}")
  scheduledFor   DateTime?           @map("scheduled_for")
  sentAt         DateTime?           @map("sent_at")
  attempts       Int                 @default(0)
  lastError      String?             @map("last_error") @db.VarChar(500)
  deviceId       String?             @map("device_id") @db.Uuid
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  device         NotificationDevice? @relation(fields: [deviceId], references: [deviceId])

  @@index([status], map: "idx_notifications_status")
  @@index([scheduledFor], map: "idx_notifications_scheduled_for")
  @@index([deviceId], map: "idx_notifications_device_id")
  @@map("notifications")
}

/// Attributed search history rows fan out by entity and market scope.
/// A DB-level unique index named uq_search_log_request_entity_market enforces
/// idempotency on searchRequestId + entityId + marketKey + collectableMarketKey
/// because Prisma cannot model the COALESCE expression used for null scope.
/// One row per submitted search (query-level facts). History, recents, and query
/// suggestions read this table directly — no per-entity dedup, because a search is
/// already exactly one row. Per-attribution facts live in SearchEventEntity.
model SearchEvent {
  eventId                String              @id @default(dbgenerated("gen_random_uuid()")) @map("event_id") @db.Uuid
  searchRequestId        String              @map("search_request_id") @db.Uuid
  userId                 String?             @map("user_id") @db.Uuid
  queryText              String?             @map("query_text") @db.VarChar(500)
  eventKind              SearchEventKind     @default(backend) @map("event_kind")
  primaryMarketKey       String?             @map("primary_market_key") @db.VarChar(255)
  totalResults           Int?                @map("total_results")
  totalFoodResults       Int?                @map("total_food_results")
  totalRestaurantResults Int?                @map("total_restaurant_results")
  queryExecutionTimeMs   Int?                @map("query_execution_time_ms")
  marketStatus           String?             @map("market_status") @db.VarChar(32)
  submissionSource       String?             @map("submission_source") @db.VarChar(32)
  metadata               Json?               @default("{}")
  loggedAt               DateTime            @default(now()) @map("logged_at")
  user                   User?               @relation(fields: [userId], references: [userId], onDelete: SetNull)
  entities               SearchEventEntity[]

  @@unique([searchRequestId], map: "uq_search_events_request")
  @@index([userId, queryText], map: "idx_search_events_user_query")
  @@index([userId, eventKind, loggedAt(sort: Desc)], map: "idx_search_events_user_kind_time")
  @@index([queryText], map: "idx_search_events_query_text")
  @@index([eventKind, loggedAt(sort: Desc)], map: "idx_search_events_kind_time")
  @@index([primaryMarketKey, eventKind, loggedAt(sort: Desc)], map: "idx_search_events_market_kind_time")
  @@map("search_events")
}

/// One row per (attributed entity x market scope) for a search event. Demand
/// aggregation and autocomplete popularity read this per-entity table. eventKind
/// and loggedAt are denormalized from the parent event so per-entity scans stay
/// single-table and index-only (the same access shape the old user_search_logs had).
model SearchEventEntity {
  attributionId        String          @id @default(dbgenerated("gen_random_uuid()")) @map("attribution_id") @db.Uuid
  eventId              String          @map("event_id") @db.Uuid
  entityId             String          @map("entity_id") @db.Uuid
  entityType           EntityType      @map("entity_type")
  userId               String?         @map("user_id") @db.Uuid
  marketKey            String?         @map("market_key") @db.VarChar(255)
  collectableMarketKey String?         @map("collectable_market_key") @db.VarChar(255)
  rank                 Int?            @map("rank")
  eventKind            SearchEventKind @map("event_kind")
  loggedAt             DateTime        @map("logged_at")
  event                SearchEvent     @relation(fields: [eventId], references: [eventId], onDelete: Cascade)
  entity               Entity          @relation(fields: [entityId], references: [entityId], onDelete: Cascade)

  @@index([eventId], map: "idx_search_event_entities_event")
  @@index([entityId, userId], map: "idx_search_event_entities_entity_user")
  @@index([entityId, marketKey, loggedAt], map: "idx_search_event_entities_entity_market_time")
  @@index([entityId, collectableMarketKey, loggedAt], map: "idx_search_event_entities_entity_collectable_time")
  @@index([entityId, eventKind, loggedAt(sort: Desc)], map: "idx_search_event_entities_entity_kind_time")
  @@index([marketKey, eventKind, loggedAt(sort: Desc)], map: "idx_search_event_entities_market_kind_time")
  @@index([collectableMarketKey, eventKind, loggedAt(sort: Desc)], map: "idx_search_event_entities_collectable_kind_time")
  @@map("search_event_entities")
}

/// Rebuildable daily demand facts. A DB-level unique index named
/// uq_search_demand_daily_scope uses NULLS NOT DISTINCT so null global/UI/
/// collectable scopes are idempotent; Prisma cannot model that index variant.
model UserSearchDemandDaily {
  demandDailyId        String            @id @default(dbgenerated("gen_random_uuid()")) @map("demand_daily_id") @db.Uuid
  demandDate           DateTime          @map("demand_date") @db.Date
  userId               String?           @map("user_id") @db.Uuid
  marketKey            String?           @map("market_key") @db.VarChar(255)
  collectableMarketKey String?           @map("collectable_market_key") @db.VarChar(255)
  subjectKind          DemandSubjectKind @map("subject_kind")
  subjectKey           String            @map("subject_key") @db.VarChar(500)
  entityId             String?           @map("entity_id") @db.Uuid
  entityType           EntityType?       @map("entity_type")
  normalizedText       String?           @map("normalized_text") @db.VarChar(500)
  sourceKind           DemandSourceKind  @map("source_kind")
  signalKind           DemandSignalKind  @map("signal_kind")
  reason               String?           @db.VarChar(64)
  signalCount          Int               @default(0) @map("signal_count")
  firstSeenAt          DateTime          @map("first_seen_at")
  lastSeenAt           DateTime          @map("last_seen_at")
  metadata             Json?             @default("{}")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @default(now()) @updatedAt @map("updated_at")
  entity               Entity?           @relation(fields: [entityId], references: [entityId], onDelete: Cascade)
  user                 User?             @relation(fields: [userId], references: [userId], onDelete: SetNull)

  @@index([demandDate], map: "idx_search_demand_daily_date")
  @@index([subjectKind, subjectKey, demandDate], map: "idx_search_demand_daily_subject_date")
  @@index([entityId, demandDate], map: "idx_search_demand_daily_entity_date")
  @@index([marketKey, subjectKind, demandDate], map: "idx_search_demand_daily_market_subject_date")
  @@index([collectableMarketKey, subjectKind, demandDate], map: "idx_search_demand_daily_collectable_subject_date")
  @@index([sourceKind, signalKind, demandDate], map: "idx_search_demand_daily_source_signal_date")
  @@index([userId, demandDate], map: "idx_search_demand_daily_user_date")
  @@map("user_search_demand_daily")
}

model DemandScoringRun {
  runId                String                    @id @default(dbgenerated("gen_random_uuid()")) @map("run_id") @db.Uuid
  consumerKind         DemandScoringConsumerKind @map("consumer_kind")
  marketKey            String?                   @map("market_key") @db.VarChar(255)
  collectableMarketKey String?                   @map("collectable_market_key") @db.VarChar(255)
  cycleStartAt         DateTime                  @map("cycle_start_at")
  cycleEndAt           DateTime                  @map("cycle_end_at")
  scorerVersion        String                    @map("scorer_version") @db.VarChar(64)
  traceAllCandidates   Boolean                   @default(false) @map("trace_all_candidates")
  startedAt            DateTime                  @default(now()) @map("started_at")
  finishedAt           DateTime?                 @map("finished_at")
  metadata             Json?                     @default("{}")
  candidates           DemandScoringCandidate[]

  @@index([consumerKind, startedAt(sort: Desc)], map: "idx_demand_scoring_runs_consumer_started")
  @@index([marketKey, consumerKind, startedAt(sort: Desc)], map: "idx_demand_scoring_runs_market_consumer")
  @@index([collectableMarketKey, consumerKind, startedAt(sort: Desc)], map: "idx_demand_scoring_runs_collectable_consumer")
  @@map("demand_scoring_runs")
}

/// Batch scoring trace candidate. A DB-level unique index named
/// uq_demand_scoring_candidate_scope uses NULLS NOT DISTINCT across candidate
/// identity and scope to protect createMany(skipDuplicates) trace writes.
model DemandScoringCandidate {
  candidateId          String                     @id @default(dbgenerated("gen_random_uuid()")) @map("candidate_id") @db.Uuid
  runId                String                     @map("run_id") @db.Uuid
  consumerKind         DemandScoringConsumerKind  @map("consumer_kind")
  candidateKind        String                     @map("candidate_kind") @db.VarChar(64)
  subjectKind          DemandSubjectKind          @map("subject_kind")
  subjectKey           String                     @map("subject_key") @db.VarChar(500)
  entityId             String?                    @map("entity_id") @db.Uuid
  entityType           EntityType?                @map("entity_type")
  normalizedText       String?                    @map("normalized_text") @db.VarChar(500)
  marketKey            String?                    @map("market_key") @db.VarChar(255)
  collectableMarketKey String?                    @map("collectable_market_key") @db.VarChar(255)
  bucket               String?                    @db.VarChar(64)
  lane                 String?                    @db.VarChar(64)
  reason               String?                    @db.VarChar(64)
  finalScore           Float?                     @map("final_score")
  rank                 Int?
  selected             Boolean                    @default(false)
  decisionState        DemandScoringDecisionState @map("decision_state")
  decisionReason       String?                    @map("decision_reason") @db.VarChar(255)
  factorBreakdown      Json?                      @default("{}") @map("factor_breakdown")
  createdAt            DateTime                   @default(now()) @map("created_at")
  entity               Entity?                    @relation(fields: [entityId], references: [entityId], onDelete: SetNull)
  run                  DemandScoringRun           @relation(fields: [runId], references: [runId], onDelete: Cascade)

  @@index([runId, rank], map: "idx_demand_scoring_candidates_run_rank")
  @@index([consumerKind, selected, createdAt(sort: Desc)], map: "idx_demand_scoring_candidates_consumer_selected")
  @@index([subjectKind, subjectKey, consumerKind], map: "idx_demand_scoring_candidates_subject_consumer")
  @@index([entityId, consumerKind], map: "idx_demand_scoring_candidates_entity_consumer")
  @@map("demand_scoring_candidates")
}

model RestaurantView {
  userId       String   @map("user_id") @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  lastViewedAt DateTime @default(now()) @map("last_viewed_at")
  viewCount    Int      @default(1) @map("view_count")
  metadata     Json?    @default("{}")
  user         User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  restaurant   Entity   @relation(fields: [restaurantId], references: [entityId], onDelete: Cascade)

  @@id([userId, restaurantId])
  @@index([userId, lastViewedAt(sort: Desc)], map: "idx_restaurant_views_user_time")
  @@index([restaurantId], map: "idx_restaurant_views_restaurant")
  @@map("user_restaurant_views")
