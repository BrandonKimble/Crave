model FavoriteList {
  listId        String                     @id @default(dbgenerated("gen_random_uuid()")) @map("list_id") @db.Uuid
  ownerUserId   String                     @map("owner_user_id") @db.Uuid
  name          String                     @db.VarChar(120)
  description   String?                    @db.VarChar(500)
  listType      FavoriteListType           @map("list_type")
  visibility    FavoriteListVisibility     @default(private) @map("visibility")
  itemCount     Int                        @default(0) @map("item_count")
  position      Int                        @default(0) @map("position")
  shareSlug     String?                    @unique(map: "favorite_lists_share_slug_key") @map("share_slug") @db.VarChar(64)
  shareEnabled  Boolean                    @default(false) @map("share_enabled")
  /// Auto-created default lists (page-registry §8.7): 'been' | 'want_to_go'
  /// (restaurant side), 'tried' | 'want_to_try' (dish side). NULL = a normal
