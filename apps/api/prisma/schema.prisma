generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "darwin"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [btree_gin, pg_trgm, postgis]
}

model Entity {
  entityId                            String                @id @default(dbgenerated("gen_random_uuid()")) @map("entity_id") @db.Uuid
  name                                String                @db.VarChar(255)
  type                                EntityType
  canonicalDomain                     String?               @map("canonical_domain") @db.VarChar(255)
  aliases                             String[]              @default([])
  restaurantAttributes                String[]              @default([]) @map("restaurant_attributes") @db.Uuid
  restaurantQualityScore              Decimal?              @default(0) @map("restaurant_quality_score") @db.Decimal(10, 4)
  latitude                            Decimal?              @db.Decimal(10, 8)
  longitude                           Decimal?              @db.Decimal(11, 8)
  address                             String?               @db.VarChar(500)
  restaurantMetadata                  Json?                 @map("restaurant_metadata")
  primaryLocationId                   String?               @unique @map("primary_location_id") @db.Uuid
  lastUpdated                         DateTime              @default(now()) @map("last_updated")
  createdAt                           DateTime              @default(now()) @map("created_at")
  generalPraiseUpvotes                Int?                  @default(0) @map("general_praise_upvotes")
  city                                String?               @map("city") @db.VarChar(255)
  region                              String?               @map("region") @db.VarChar(255)
  country                             String?               @map("country") @db.VarChar(2)
  postalCode                          String?               @map("postal_code") @db.VarChar(32)
  priceLevel                          Int?                  @map("price_level")
  priceLevelUpdatedAt                 DateTime?             @map("price_level_updated_at")
  lastPolledAt                        DateTime?             @map("last_polled_at")
  foodConnections                     Connection[]          @relation("FoodEntity")
  restaurantConnections               Connection[]          @relation("RestaurantEntity")
  priorityMetrics                     EntityPriorityMetric?
  onDemandRequests                    OnDemandRequest[]
  pollOptionCategories                PollOption[]          @relation("PollOptionCategoryEntity")
  pollOptions                         PollOption[]          @relation("PollOptionPrimaryEntity")
  pollOptionFoods                     PollOption[]          @relation("PollOptionFoodEntity")
  pollOptionRestaurants               PollOption[]          @relation("PollOptionRestaurantEntity")
  pollTopicDishTargets                PollTopic[]           @relation("PollTopicTargetDish")
  pollTopicRestaurantTargets          PollTopic[]           @relation("PollTopicTargetRestaurant")
  pollTopicFoodAttributeTargets       PollTopic[]           @relation("PollTopicTargetFoodAttribute")
  pollTopicRestaurantAttributeTargets PollTopic[]           @relation("PollTopicTargetRestaurantAttribute")
  searchLogs                          SearchLog[]
  userFavorites                       UserFavorite[]
  favoriteListItems                   FavoriteListItem[]
  restaurantViews                     RestaurantView[]
  foodViews                           FoodView[]
  locations                           RestaurantLocation[]  @relation("RestaurantLocations")
  marketPresences                     EntityMarketPresence[]
  restaurantEvents                    RestaurantEvent[]     @relation("RestaurantEventRestaurant")
  restaurantEntityEvents              RestaurantEntityEvent[] @relation("RestaurantEntityEventRestaurant")
  restaurantEntityEventTargets        RestaurantEntityEvent[] @relation("RestaurantEntityEventTarget")
  restaurantEntitySignals             RestaurantEntitySignal[] @relation("RestaurantEntitySignalRestaurant")
  restaurantEntitySignalTargets       RestaurantEntitySignal[] @relation("RestaurantEntitySignalTarget")
  primaryLocation                     RestaurantLocation?   @relation("PrimaryLocation", fields: [primaryLocationId], references: [locationId])

  @@index([type], map: "idx_entities_type")
  @@index([type, restaurantQualityScore(sort: Desc)], map: "idx_entities_type_score")
  @@index([name], map: "idx_entities_name")
  @@index([canonicalDomain], map: "idx_entities_canonical_domain")
  @@index([type, canonicalDomain], map: "idx_entities_type_canonical_domain")
  @@index([aliases], map: "idx_entities_aliases")
  @@index([restaurantAttributes], map: "idx_entities_restaurant_attributes")
  @@index([longitude, latitude], map: "idx_entities_location")
  @@index([address], map: "idx_entities_address")
  @@index([city], map: "idx_entities_city")
  @@index([region], map: "idx_entities_region")
  @@index([country], map: "idx_entities_country")
  @@index([priceLevel], map: "idx_entities_price_level")
  @@index([lastPolledAt], map: "idx_entities_last_polled_at")
  @@index([primaryLocationId], map: "idx_entities_primary_location")
  @@index([lastUpdated(sort: Desc)], map: "idx_entities_last_updated")
  @@index([createdAt(sort: Desc)], map: "idx_entities_created_at")
  @@map("core_entities")
}

model EntityMarketPresence {
  entityId   String   @map("entity_id") @db.Uuid
  marketKey  String   @map("market_key") @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  entity     Entity   @relation(fields: [entityId], references: [entityId], onDelete: Cascade)

  @@id([entityId, marketKey])
  @@index([marketKey], map: "idx_entity_market_presence_market_key")
  @@index([entityId], map: "idx_entity_market_presence_entity_id")
  @@map("core_entity_market_presence")
}

model RestaurantLocation {
  locationId       String    @id @default(dbgenerated("gen_random_uuid()")) @map("location_id") @db.Uuid
  restaurantId     String    @map("restaurant_id") @db.Uuid
  googlePlaceId    String?   @unique @map("google_place_id") @db.VarChar(255)
  latitude         Decimal?  @db.Decimal(10, 8)
  longitude        Decimal?  @db.Decimal(11, 8)
  address          String?   @db.VarChar(500)
  city             String?   @db.VarChar(255)
  region           String?   @db.VarChar(255)
  country          String?   @db.VarChar(2)
  postalCode       String?   @map("postal_code") @db.VarChar(32)
  phoneNumber      String?   @map("phone_number") @db.VarChar(64)
  websiteUrl       String?   @map("website_url") @db.VarChar(2048)
  websiteDomain    String?   @map("website_domain") @db.VarChar(255)
  hours            Json?     @map("hours")
  utcOffsetMinutes Int?      @map("utc_offset_minutes")
  timeZone         String?   @map("time_zone") @db.VarChar(64)
  isPrimary        Boolean   @default(false) @map("is_primary")
  lastPolledAt     DateTime? @map("last_polled_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @map("updated_at")
  restaurant       Entity    @relation("RestaurantLocations", fields: [restaurantId], references: [entityId], onDelete: Cascade)
  primaryFor       Entity?   @relation("PrimaryLocation")

  @@index([restaurantId], map: "idx_restaurant_locations_restaurant")
  @@index([restaurantId, isPrimary], map: "idx_restaurant_locations_primary")
  @@index([restaurantId, websiteDomain], map: "idx_restaurant_locations_restaurant_domain")
  @@index([longitude, latitude], map: "idx_restaurant_locations_location")
  @@index([googlePlaceId], map: "idx_restaurant_locations_google_place_id")
  @@index([websiteDomain], map: "idx_restaurant_locations_website_domain")
  @@map("core_restaurant_locations")
}

model Connection {
  connectionId           String             @id @default(dbgenerated("gen_random_uuid()")) @map("connection_id") @db.Uuid
  restaurantId           String             @map("restaurant_id") @db.Uuid
  foodId                 String             @map("food_id") @db.Uuid
  categories             String[]           @default([]) @db.Uuid
  foodAttributes         String[]           @default([]) @map("food_attributes") @db.Uuid
  mentionCount           Int                @default(0) @map("mention_count")
  totalUpvotes           Int                @default(0) @map("total_upvotes")
  recentMentionCount     Int                @default(0) @map("recent_mention_count")
  supportMentionCount               Int     @default(0) @map("support_mention_count")
  supportTotalUpvotes               Int     @default(0) @map("support_total_upvotes")
  supportRecentMentionCount         Int     @default(0) @map("support_recent_mention_count")
  lastMentionedAt        DateTime?          @map("last_mentioned_at")
  activityLevel          ActivityLevel      @default(normal) @map("activity_level")
  foodQualityScore       Decimal            @default(0) @map("food_quality_score") @db.Decimal(10, 4)
  lastUpdated            DateTime           @default(now()) @map("last_updated")
  createdAt              DateTime           @default(now()) @map("created_at")
  decayedMentionScore    Decimal            @default(0) @map("decayed_mention_score") @db.Decimal(18, 6)
  decayedUpvoteScore     Decimal            @default(0) @map("decayed_upvote_score") @db.Decimal(18, 6)
  supportDecayedMentionScore         Decimal @default(0) @map("support_decayed_mention_score") @db.Decimal(18, 6)
  supportDecayedUpvoteScore          Decimal @default(0) @map("support_decayed_upvote_score") @db.Decimal(18, 6)
  decayedScoresUpdatedAt DateTime?          @map("decayed_scores_updated_at")
  food                   Entity             @relation("FoodEntity", fields: [foodId], references: [entityId])
  restaurant             Entity             @relation("RestaurantEntity", fields: [restaurantId], references: [entityId])
  pollOptions            PollOption[]       @relation("PollOptionConnection")
  favoriteListItems      FavoriteListItem[]
  FoodView               FoodView[]

  @@unique([restaurantId, foodId])
  @@index([restaurantId], map: "idx_connections_restaurant")
  @@index([foodId], map: "idx_connections_food")
  @@index([categories], map: "idx_connections_categories_gin", type: Gin)
  @@index([foodAttributes], map: "idx_connections_attributes_gin", type: Gin)
  @@index([mentionCount(sort: Desc)], map: "idx_connections_mention_count")
  @@index([totalUpvotes(sort: Desc)], map: "idx_connections_total_upvotes")
  @@index([foodQualityScore(sort: Desc)], map: "idx_connections_quality_score")
  @@index([lastMentionedAt(sort: Desc)], map: "idx_connections_last_mentioned")
  @@index([activityLevel], map: "idx_connections_activity")
  @@index([restaurantId, foodQualityScore(sort: Desc)], map: "idx_connections_restaurant_quality")
  @@index([foodId, foodQualityScore(sort: Desc)], map: "idx_connections_food_quality")
  @@index([restaurantId, mentionCount(sort: Desc)], map: "idx_connections_restaurant_mentions")
  @@index([foodId, mentionCount(sort: Desc)], map: "idx_connections_food_mentions")
  @@index([lastUpdated(sort: Desc)], map: "idx_connections_last_updated")
  @@index([createdAt(sort: Desc)], map: "idx_connections_created_at")
  @@index([recentMentionCount(sort: Desc)], map: "idx_connections_recent_mentions")
  @@map("core_restaurant_items")
}

model DisplayRankScore {
  marketKey        String                 @map("market_key") @db.VarChar(255)
  subjectType      DisplayRankSubjectType @map("subject_type")
  subjectId        String                 @map("subject_id") @db.Uuid
  rankScoreRaw     Decimal                @map("rank_score_raw") @db.Decimal(9, 4)
  rankScoreDisplay Decimal                @map("rank_score_display") @db.Decimal(5, 1)
  rankPercentile   Decimal                @map("rank_percentile") @db.Decimal(6, 5)
  computedAt       DateTime               @default(now()) @map("computed_at")

  @@id([marketKey, subjectType, subjectId])
  @@index([marketKey, subjectType], map: "idx_display_rank_market_type")
  @@index([subjectType, subjectId], map: "idx_display_rank_subject")
  @@map("core_display_rank_scores")
}

model PollCategoryAggregate {
  restaurantId   String    @map("restaurant_id") @db.Uuid
  categoryId     String    @map("category_id") @db.Uuid
  pseudoMentions Decimal   @default(0) @map("pseudo_mentions") @db.Decimal(18, 6)
  pseudoUpvotes  Decimal   @default(0) @map("pseudo_upvotes") @db.Decimal(18, 6)
  voteCount      Int       @default(0) @map("vote_count")
  lastVoteAt     DateTime? @map("last_vote_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@id([restaurantId, categoryId])
  @@index([categoryId], map: "idx_poll_category_aggregate_category")
  @@map("poll_category_aggregates")
}

model ProcessedSource {
  pipeline    String   @db.VarChar(32)
  sourceId    String   @map("source_id") @db.VarChar(64)
  community   String?  @db.VarChar(100)
  processedAt DateTime @default(now()) @map("processed_at")

  @@id([pipeline, sourceId])
  @@index([pipeline], map: "idx_processed_source_pipeline")
  @@index([community], map: "idx_processed_source_community")
  @@index([processedAt(sort: Desc)], map: "idx_processed_source_processed_at")
  @@map("collection_processed_sources")
}

model SourceDocument {
  documentId             String                   @id @default(dbgenerated("gen_random_uuid()")) @map("document_id") @db.Uuid
  platform               String                   @default("reddit") @db.VarChar(32)
  community              String?                  @db.VarChar(100)
  sourceType             MentionSource            @map("source_type")
  sourceId               String                   @map("source_id") @db.VarChar(64)
  parentSourceId         String?                  @map("parent_source_id") @db.VarChar(64)
  title                  String?                  @db.Text
  body                   String?                  @db.Text
  url                    String?                  @db.VarChar(2048)
  sourceCreatedAt        DateTime                 @map("source_created_at")
  collectedAt            DateTime                 @default(now()) @map("collected_at")
  scoreSnapshot          Int?                     @map("score_snapshot")
  rawPayload             Json?                    @map("raw_payload")
  activeExtractionRunId  String?                  @map("active_extraction_run_id") @db.Uuid
  activeExtractionRun    ExtractionRun?           @relation("ActiveExtractionRunDocuments", fields: [activeExtractionRunId], references: [extractionRunId], onDelete: SetNull)
  extractionInputs       ExtractionInputDocument[]
  restaurantEvents       RestaurantEvent[]
  restaurantEntityEvents RestaurantEntityEvent[]

  @@unique([platform, sourceType, sourceId], map: "source_documents_platform_type_source_id_key")
  @@index([community], map: "idx_source_documents_community")
  @@index([sourceCreatedAt(sort: Desc)], map: "idx_source_documents_created_at")
  @@index([activeExtractionRunId], map: "idx_source_documents_active_run")
  @@map("collection_source_documents")
}

model CollectionRun {
  collectionRunId String         @id @default(dbgenerated("gen_random_uuid()")) @map("collection_run_id") @db.Uuid
  scopeKey        String         @unique @map("scope_key") @db.VarChar(255)
  pipeline        String         @db.VarChar(32)
  platform        String?        @db.VarChar(32)
  community       String?        @db.VarChar(255)
  status          String         @db.VarChar(32)
  startedAt       DateTime       @default(now()) @map("started_at")
  completedAt     DateTime?      @map("completed_at")
  metadata        Json?          @default("{}")
  extractionRuns  ExtractionRun[]

  @@index([pipeline, startedAt(sort: Desc)], map: "idx_collection_runs_pipeline_started_at")
  @@index([status], map: "idx_collection_runs_status")
  @@map("collection_runs")
}

model ExtractionRun {
  extractionRunId     String                   @id @default(dbgenerated("gen_random_uuid()")) @map("extraction_run_id") @db.Uuid
  collectionRunId     String?                  @map("collection_run_id") @db.Uuid
  pipeline            String                   @db.VarChar(32)
  model               String                   @db.VarChar(128)
  systemPromptHash    String                   @map("system_prompt_hash") @db.VarChar(64)
  systemPrompt        String                   @map("system_prompt") @db.Text
  generationConfig    Json                     @default("{}") @map("generation_config")
  chunkingConfig      Json                     @default("{}") @map("chunking_config")
  extractionSchemaVersion String              @default("v1") @map("extraction_schema_version") @db.VarChar(32)
  status              String                   @db.VarChar(32)
  startedAt           DateTime                 @default(now()) @map("started_at")
  completedAt         DateTime?                @map("completed_at")
  metadata            Json?                    @default("{}")
  collectionRun       CollectionRun?           @relation(fields: [collectionRunId], references: [collectionRunId], onDelete: SetNull)
  inputs              ExtractionInput[]
  activeForDocuments  SourceDocument[]         @relation("ActiveExtractionRunDocuments")
  restaurantEvents    RestaurantEvent[]
  restaurantEntityEvents RestaurantEntityEvent[]

  @@index([pipeline, startedAt(sort: Desc)], map: "idx_extraction_runs_pipeline_started_at")
  @@index([collectionRunId], map: "idx_extraction_runs_collection_run_id")
  @@index([status], map: "idx_extraction_runs_status")
  @@map("collection_extraction_runs")
}

model ExtractionInput {
  inputId                String                   @id @default(dbgenerated("gen_random_uuid()")) @map("input_id") @db.Uuid
  extractionRunId        String                   @map("extraction_run_id") @db.Uuid
  inputIndex             Int                      @map("input_index")
  inputPayload           Json                     @map("input_payload")
  rawOutput              Json?                    @map("raw_output")
  createdAt              DateTime                 @default(now()) @map("created_at")
  extractionRun          ExtractionRun            @relation(fields: [extractionRunId], references: [extractionRunId], onDelete: Cascade)
  sourceDocuments        ExtractionInputDocument[]
  restaurantEvents       RestaurantEvent[]
  restaurantEntityEvents RestaurantEntityEvent[]

  @@unique([extractionRunId, inputIndex], map: "extraction_inputs_run_index_key")
  @@index([extractionRunId], map: "idx_extraction_inputs_run")
  @@map("collection_extraction_inputs")
}

model ExtractionInputDocument {
  inputId     String          @map("input_id") @db.Uuid
  documentId  String          @map("document_id") @db.Uuid
  ordinal     Int
  input       ExtractionInput @relation(fields: [inputId], references: [inputId], onDelete: Cascade)
  document     SourceDocument @relation(fields: [documentId], references: [documentId], onDelete: Cascade)

  @@id([inputId, documentId])
  @@index([documentId], map: "idx_extraction_input_documents_document")
  @@index([inputId, ordinal], map: "idx_extraction_input_documents_input_ordinal")
  @@map("collection_extraction_input_documents")
}

model RestaurantEvent {
  eventId           String         @id @default(dbgenerated("gen_random_uuid()")) @map("event_id") @db.Uuid
  extractionRunId   String         @map("extraction_run_id") @db.Uuid
  inputId           String         @map("input_id") @db.Uuid
  sourceDocumentId  String         @map("source_document_id") @db.Uuid
  restaurantId      String         @map("restaurant_id") @db.Uuid
  mentionKey        String         @map("mention_key") @db.VarChar(255)
  evidenceType      String         @map("evidence_type") @db.VarChar(64)
  mentionedAt       DateTime       @map("mentioned_at")
  sourceUpvotes     Int            @default(0) @map("source_upvotes")
  metadata          Json?          @default("{}")
  createdAt         DateTime       @default(now()) @map("created_at")
  extractionRun     ExtractionRun  @relation(fields: [extractionRunId], references: [extractionRunId], onDelete: Cascade)
  input             ExtractionInput @relation(fields: [inputId], references: [inputId], onDelete: Cascade)
  sourceDocument    SourceDocument @relation(fields: [sourceDocumentId], references: [documentId], onDelete: Cascade)
  restaurant        Entity         @relation("RestaurantEventRestaurant", fields: [restaurantId], references: [entityId], onDelete: Cascade)

  @@unique([extractionRunId, mentionKey, restaurantId, evidenceType], map: "restaurant_events_run_mention_restaurant_type_key")
  @@index([restaurantId, mentionedAt(sort: Desc)], map: "idx_restaurant_events_restaurant_time")
  @@index([sourceDocumentId], map: "idx_restaurant_events_source_document")
  @@index([extractionRunId], map: "idx_restaurant_events_run")
  @@map("core_restaurant_events")
}

model RestaurantEntityEvent {
  eventId           String          @id @default(dbgenerated("gen_random_uuid()")) @map("event_id") @db.Uuid
  extractionRunId   String          @map("extraction_run_id") @db.Uuid
  inputId           String          @map("input_id") @db.Uuid
  sourceDocumentId  String          @map("source_document_id") @db.Uuid
  restaurantId      String          @map("restaurant_id") @db.Uuid
  mentionKey        String          @map("mention_key") @db.VarChar(255)
  entityId          String          @map("entity_id") @db.Uuid
  entityType        EntityType      @map("entity_type")
  evidenceType      String          @map("evidence_type") @db.VarChar(64)
  isMenuItem        Boolean?        @map("is_menu_item")
  mentionedAt       DateTime        @map("mentioned_at")
  sourceUpvotes     Int             @default(0) @map("source_upvotes")
  metadata          Json?           @default("{}")
  createdAt         DateTime        @default(now()) @map("created_at")
  extractionRun     ExtractionRun   @relation(fields: [extractionRunId], references: [extractionRunId], onDelete: Cascade)
  input             ExtractionInput @relation(fields: [inputId], references: [inputId], onDelete: Cascade)
  sourceDocument    SourceDocument  @relation(fields: [sourceDocumentId], references: [documentId], onDelete: Cascade)
  restaurant        Entity          @relation("RestaurantEntityEventRestaurant", fields: [restaurantId], references: [entityId], onDelete: Cascade)
  entity            Entity          @relation("RestaurantEntityEventTarget", fields: [entityId], references: [entityId], onDelete: Cascade)

  @@unique([extractionRunId, mentionKey, restaurantId, entityId, evidenceType], map: "restaurant_entity_events_run_mention_restaurant_entity_type_key")
  @@index([restaurantId, mentionedAt(sort: Desc)], map: "idx_restaurant_entity_events_restaurant_time")
  @@index([entityId, mentionedAt(sort: Desc)], map: "idx_restaurant_entity_events_entity_time")
  @@index([sourceDocumentId], map: "idx_restaurant_entity_events_source_document")
  @@index([extractionRunId], map: "idx_restaurant_entity_events_run")
  @@map("core_restaurant_entity_events")
}

model RestaurantEntitySignal {
  restaurantId  String     @map("restaurant_id") @db.Uuid
  entityId      String     @map("entity_id") @db.Uuid
  entityType    EntityType @map("entity_type")
  mentionCount  Int        @default(0) @map("mention_count")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  restaurant    Entity     @relation("RestaurantEntitySignalRestaurant", fields: [restaurantId], references: [entityId], onDelete: Cascade)
  entity        Entity     @relation("RestaurantEntitySignalTarget", fields: [entityId], references: [entityId], onDelete: Cascade)

  @@id([restaurantId, entityId])
  @@index([entityId, mentionCount(sort: Desc)], map: "idx_restaurant_entity_signals_entity_mentions")
  @@index([restaurantId, mentionCount(sort: Desc)], map: "idx_restaurant_entity_signals_restaurant_mentions")
  @@index([restaurantId, entityType, mentionCount(sort: Desc)], map: "idx_restaurant_entity_signals_restaurant_type_mentions")
  @@map("core_restaurant_entity_signals")
}

model EntityPriorityMetric {
  entityId               String     @id @map("entity_id") @db.Uuid
  entityType             EntityType @map("entity_type")
  lastCalculatedAt       DateTime   @default(now()) @map("last_calculated_at")
  queryImpressions       Int        @default(0) @map("query_impressions")
  lastQueryAt            DateTime?  @map("last_query_at")
  viewImpressions        Int        @default(0) @map("view_impressions")
  lastViewAt             DateTime?  @map("last_view_at")
  favoriteCount          Int        @default(0) @map("favorite_count")
  autocompleteSelections Int        @default(0) @map("autocomplete_selections")
  entity                 Entity     @relation(fields: [entityId], references: [entityId], onDelete: Cascade)

  @@index([entityType], map: "idx_entity_priority_type")
  @@index([lastCalculatedAt(sort: Desc)], map: "idx_entity_priority_calculated")
  @@map("collection_entity_priority_metrics")
}

model PollTopic {
  topicId                     String          @id @default(dbgenerated("gen_random_uuid()")) @map("topic_id") @db.Uuid
  title                       String          @db.VarChar(255)
  description                 String?         @db.VarChar(500)
  marketKey                   String?         @map("market_key") @db.VarChar(255)
  region                      String?         @db.VarChar(255)
  country                     String?         @db.VarChar(2)
  categoryEntityIds           String[]        @default([]) @map("category_entity_ids") @db.Uuid
  seedEntityIds               String[]        @default([]) @map("seed_entity_ids") @db.Uuid
  status                      PollTopicStatus @default(draft)
  metadata                    Json?           @default("{}")
  createdByUserId             String?         @map("created_by_user_id") @db.Uuid
  createdAt                   DateTime        @default(now()) @map("created_at")
  updatedAt                   DateTime        @updatedAt @map("updated_at")
  targetDishId                String?         @map("target_dish_id") @db.Uuid
  targetRestaurantId          String?         @map("target_restaurant_id") @db.Uuid
  targetFoodAttributeId       String?         @map("target_food_attribute_id") @db.Uuid
  targetRestaurantAttributeId String?         @map("target_restaurant_attribute_id") @db.Uuid
  topicType                   PollTopicType   @default(best_dish) @map("topic_type")
  targetDish                  Entity?         @relation("PollTopicTargetDish", fields: [targetDishId], references: [entityId])
  targetRestaurant            Entity?         @relation("PollTopicTargetRestaurant", fields: [targetRestaurantId], references: [entityId])
  targetFoodAttribute         Entity?         @relation("PollTopicTargetFoodAttribute", fields: [targetFoodAttributeId], references: [entityId])
  targetRestaurantAttribute   Entity?         @relation("PollTopicTargetRestaurantAttribute", fields: [targetRestaurantAttributeId], references: [entityId])
  polls                       Poll[]

  @@index([marketKey], map: "idx_poll_topics_market_key")
  @@index([createdByUserId], map: "idx_poll_topics_created_by_user")
  @@index([status], map: "idx_poll_topics_status")
  @@map("poll_topics")
}

model Poll {
