/// UGC PHOTO LEDGER (product/images.md): every photo belongs to a restaurant
/// (required) and optionally to a Connection (the dish-at-restaurant).
/// Lifecycle: pending (uploaded, moderation in flight) -> live | removed
/// (failed moderation) | hidden (report threshold). Bytes live in Cloudinary
/// (publicId); delivery URLs are built server-side only.
model Photo {
  photoId         String          @id @default(dbgenerated("gen_random_uuid()")) @map("photo_id") @db.Uuid
  userId          String          @map("user_id") @db.Uuid
  restaurantId    String          @map("restaurant_id") @db.Uuid
  connectionId    String?         @map("connection_id") @db.Uuid
  /// Cloudinary public_id (crave/{env}/photos/{photoId}); set at ticket time.
  publicId        String          @unique @map("public_id") @db.VarChar(256)
  mediaType       String          @default("photo") @map("media_type") @db.VarChar(16)
  status          PhotoStatus     @default(pending)
  /// Uploader-chosen audience: private photos surface ONLY to the uploader
  /// (own food log / own reads); every public read path excludes them.
  visibility      PhotoVisibility @default(public)
  caption         String?         @db.VarChar(512)
  /// EXIF DateTimeOriginal (capture time) — GPS is NEVER persisted.
  takenAt         DateTime?       @map("taken_at")
  uploadedAt      DateTime        @default(now()) @map("uploaded_at")
  /// Cloudinary quality_analysis focus score 0..1 (blur<->sharp).
  focusScore      Float?          @map("focus_score")
  width           Int?
  height          Int?
  bytes           Int?
  reportCount     Int             @default(0) @map("report_count")
  /// Unmatched dish name from the "Other..." free text — demand signal;
  /// re-linkable when the dish materializes.
  pendingDishName String?         @map("pending_dish_name") @db.VarChar(256)
  moderatedAt     DateTime?       @map("moderated_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  user            User            @relation(fields: [userId], references: [userId], onDelete: Cascade)
  restaurant      Entity          @relation("RestaurantPhotos", fields: [restaurantId], references: [entityId], onDelete: Cascade)
  connection      Connection?     @relation(fields: [connectionId], references: [connectionId], onDelete: SetNull)

  reports PhotoReport[]

  @@index([restaurantId, status, uploadedAt(sort: Desc)], map: "idx_photos_restaurant_status")
  @@index([connectionId, status, uploadedAt(sort: Desc)], map: "idx_photos_connection_status")
  @@index([userId, status, uploadedAt(sort: Desc)], map: "idx_photos_user_status")
  @@index([status], map: "idx_photos_status")
  @@map("photos")
}

