{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": false,
    "tsConfigPath": "tsconfig.app.json",
    "watchAssets": true,
    "assets": [
      {
        "include": "modules/external-integrations/llm/prompts/*.md",
        "outDir": "dist"
      }
    ]
  }
}