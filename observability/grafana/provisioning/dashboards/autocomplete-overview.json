{
  "uid": "autocomplete-overview",
  "title": "Crave Autocomplete Overview",
  "tags": ["crave-search", "backend", "autocomplete"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Autocomplete Request Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "crave-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "req/s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(autocomplete_request_duration_seconds_count[5m]))",
          "legendFormat": "all requests",
          "refId": "A"
        },
        {
          "expr": "sum(rate(autocomplete_request_duration_seconds_count[5m])) by (cache_result)",
          "legendFormat": "{{cache_result}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Autocomplete Request Duration p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "crave-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.12 },
              { "color": "red", "value": 0.2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(autocomplete_request_duration_seconds_bucket[5m])) by (le, cache_result))",
          "legendFormat": "{{cache_result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Autocomplete Request Duration p50",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "crave-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(autocomplete_request_duration_seconds_bucket[5m])) by (le, cache_result))",
          "legendFormat": "{{cache_result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Autocomplete DB Duration p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "crave-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.08 },
              { "color": "red", "value": 0.15 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(autocomplete_request_db_duration_seconds_bucket[5m])) by (le, cache_result))",
          "legendFormat": "{{cache_result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Autocomplete DB Mean Duration",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "crave-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(autocomplete_request_db_duration_seconds_sum[5m])) by (cache_result) / clamp_min(sum(rate(autocomplete_request_db_duration_seconds_count[5m])) by (cache_result), 1e-9)",
          "legendFormat": "{{cache_result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cache Lookups by Result",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "crave-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "req/s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(autocomplete_cache_lookups_total[5m])) by (result)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Cache Hit Ratio (5m)",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "crave-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "green", "value": 0.75 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "targets": [
        {
          "expr": "sum(rate(autocomplete_cache_lookups_total{result=\"hit\"}[5m])) / clamp_min(sum(rate(autocomplete_cache_lookups_total{result=~\"hit|miss\"}[5m])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "DB Share of Total Time (5m)",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "crave-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.6 },
              { "color": "red", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "targets": [
        {
          "expr": "sum(rate(autocomplete_request_db_duration_seconds_sum[5m])) / clamp_min(sum(rate(autocomplete_request_duration_seconds_sum[5m])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cache Miss Cost (Request p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "crave-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(autocomplete_request_duration_seconds_bucket{cache_result=\"miss\"}[5m])) by (le))",
          "legendFormat": "miss p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(autocomplete_request_duration_seconds_bucket{cache_result=\"hit\"}[5m])) by (le))",
          "legendFormat": "hit p95",
          "refId": "B"
        }
      ]
    }
  ]
}
