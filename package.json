{
  "name": "crave-search",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "app-route:delete-gate": "bash ./scripts/app-route-runtime-delete-gate.sh",
    "tomtom-market:delete-gate": "bash ./scripts/tomtom-market-cutover-delete-gate.sh",
    "tomtom-market:deploy-gate": "bash ./scripts/tomtom-market-deploy-gate.sh",
    "tomtom-market:fixtures": "yarn workspace api tomtom:fixtures",
    "tomtom-market:health": "yarn workspace api tomtom:regional-health",
    "search-demand:delete-gate": "bash ./scripts/search-demand-cutover-delete-gate.sh",
    "search-demand:rebuild": "yarn workspace api search-demand:rebuild",
    "search-demand:fixtures": "yarn workspace api search-demand:fixtures",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:staged:api": "bash ./scripts/eslint-staged-package.sh apps/api",
    "lint:staged:api:fix": "bash ./scripts/eslint-staged-package.sh --fix apps/api",
    "lint:staged:mobile": "bash ./scripts/eslint-staged-package.sh apps/mobile",
    "lint:staged:mobile:fix": "bash ./scripts/eslint-staged-package.sh --fix apps/mobile",
    "lint:staged:shared": "bash ./scripts/eslint-staged-package.sh packages/shared",
    "lint:staged:shared:fix": "bash ./scripts/eslint-staged-package.sh --fix packages/shared",
    "deps-check": "bash ./scripts/deps-check.sh",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:migrate": "turbo run db:migrate",
    "db:generate": "turbo run db:generate",
    "android": "yarn workspace @crave-search/mobile android",
    "ios": "yarn workspace @crave-search/mobile ios",
    "ios:refresh": "IOS_DEVICE_UDID= IOS_DEVICE_NAME= IOS_SIMULATOR_UDID= IOS_SIMULATOR_NAME= bash ./scripts/ios-refresh.sh",
    "ios:sim": "IOS_PREFER_DEVICE=0 IOS_REQUIRE_DEVICE=0 IOS_RUN=0 bash ./scripts/ios-refresh.sh",
    "ios:sim:install": "IOS_PREFER_DEVICE=0 IOS_REQUIRE_DEVICE=0 IOS_RUN=1 IOS_REQUIRE_OPEN=1 bash ./scripts/ios-refresh.sh",
    "ios:device": "IOS_PREFER_DEVICE=1 IOS_REQUIRE_DEVICE=1 IOS_RUN=0 bash ./scripts/ios-refresh.sh",
    "perf:scenario:ios": "bash ./scripts/perf-scenario-ios.sh",
    "perf:scenario:report": "node ./scripts/perf-scenario-report.js",
    "perf:scenario:contracts": "node ./scripts/perf-scenario-parity-contracts.js",
    "perf:scenario:contract-gate": "node ./scripts/perf-scenario-contract-gate.js",
    "perf:scenario:sheet-drag-contract": "node ./scripts/perf-scenario-sheet-drag-contract.js",
    "perf:scenario:interrupt-contracts": "node ./scripts/perf-scenario-interrupt-contracts.js",
    "perf:scenario:market-demand-contracts": "node ./scripts/perf-scenario-market-demand-contracts.js",
    "perf:scenario:visual-contracts": "node ./scripts/perf-scenario-visual-contracts.js",
    "test:native": "swift test --package-path apps/mobile/ios/MapLodKit",
    "visual:regression": "node ./scripts/visual-regression.js",
    "visual:regression:map": "mkdir -p /tmp/vr-map && cp /tmp/validate-*.png /tmp/vr-map/ && node ./scripts/visual-regression.js --captured /tmp/vr-map --baseline visual-baselines --pixel-threshold 0.3 --max-mismatch 0.03 --diff-out /tmp/vr-diffs",
    "ios:device:install": "EXPO_FORCE_START=1 IOS_PREFER_DEVICE=1 IOS_REQUIRE_DEVICE=1 IOS_RUN=1 IOS_REQUIRE_OPEN=1 bash ./scripts/ios-refresh.sh",
    "ios:device:reset": "IOS_PREFER_DEVICE=1 IOS_REQUIRE_DEVICE=1 IOS_RUN=0 EXPO_RESET_CACHE=1 bash ./scripts/ios-refresh.sh",
    "ios:device:tunnel": "IOS_PREFER_DEVICE=1 IOS_REQUIRE_DEVICE=1 IOS_RUN=0 EXPO_START_HOST=tunnel bash ./scripts/ios-refresh.sh",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@commitlint/cli": "^17.6.5",
    "@commitlint/config-conventional": "^17.6.5",
    "axios": "^1.8.1",
    "dotenv": "^17.2.1",
    "ioredis": "^5.5.0",
    "knip": "^6.1.0",
    "lefthook": "^1.11.2",
    "lint-staged": "^13.2.2",
    "pixelmatch": "5.3.0",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "turbo": "^1.10.0",
    "typescript": "^5.1.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "baseline-browser-mapping": "2.9.11",
    "browserslist": "4.28.1",
    "expo": "~54.0.0",
    "expo-splash-screen": "~31.0.8",
    "expo-status-bar": "~3.0.7",
    "patch-package": "^8.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
